    {
        "id": "REQUEST_BOT_FN_BEFORE_SEND",
        "type": "function",
        "z": "REQUEST_BOT_TAB_RESPONSES",
        "name": "Parse response",
        "func": "// Store NATS reply subject in global context (Matrix Send strips it)\n// Keyed by room ID since messages are processed sequentially\nglobal.set('nats_reply_' + msg.payload.topic, msg._reply);\nmsg.topic = msg.payload.topic;\nmsg.payload = msg.payload.payload;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 200,
        "wires": [
            [
                "REQUEST_BOT_MATRIX_SEND"
            ]
        ]
    },
    {
        "id": "REQUEST_BOT_MATRIX_SEND",
        "type": "matrix-send-message",
        "z": "REQUEST_BOT_TAB_RESPONSES",
        "name": "",
        "server": "REQUEST_BOT_MATRIX_SERVER",
        "roomId": "",
        "message": "",
        "messageType": "m.text",
        "messageFormat": "",
        "replaceMessage": false,
        "threadReplyType": "msg",
        "threadReplyValue": "isThread",
        "x": 520,
        "y": 200,
