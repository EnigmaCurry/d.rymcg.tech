    {
        "id": "REQUEST_BOT_FN_ROUTE_REACTION",
        "type": "function",
        "z": "REQUEST_BOT_TAB_REACTIONS",
        "name": "Route react/redact",
        "func": "var data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\n\nif (data.action === 'react') {\n    msg.topic = data.topic;\n    msg.eventId = data.eventId;\n    msg.payload = data.key;\n    msg.msgType = 'm.reaction';\n    return [msg, null];\n} else if (data.action === 'redact') {\n    msg.topic = data.topic;\n    msg.eventId = data.eventId;\n    return [null, msg];\n}\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 180,
        "wires": [
