[
    {
        "id": "REQUEST_BOT_TAB_MESSAGES",
        "type": "tab",
        "label": "REQUEST_BOT messages",
        "disabled": false,
        "info": "Receives Matrix messages and publishes to NATS for the request-bot.\nReplace REQUEST_BOT with your NATS subject prefix (e.g. hookshot.d2-admin).\nReplace MATRIX_ROOM_ID with your Matrix room ID.\nConfigure NATS and Matrix server nodes with your credentials."
    },
    {
        "id": "REQUEST_BOT_TAB_RESPONSES",
        "type": "tab",
        "label": "REQUEST_BOT responses",
        "disabled": false,
        "info": "Receives bot responses from NATS and sends them to Matrix."
    },
    {
        "id": "REQUEST_BOT_TAB_REACTIONS",
        "type": "tab",
        "label": "REQUEST_BOT reactions",
        "disabled": false,
        "info": "Handles bot reactions (add/redact) from NATS and applies them in Matrix."
    },
    {
        "id": "REQUEST_BOT_NATS_SERVER",
        "type": "nats-suite-server",
        "server": "NATS_URL",
        "authMethod": "none",
        "enableTLS": true,
        "tlsRejectUnauthorized": true,
        "tlsCaFile": "/data/certs/root_ca.crt",
        "tlsCertFile": "/data/certs/CLIENT.crt",
        "tlsKeyFile": "/data/certs/CLIENT.key",
        "maxReconnectAttempts": 10,
        "reconnectTimeWait": 1000,
        "timeout": 10000,
        "pingInterval": 30000,
        "maxPingOut": 3,
        "debug": false
    },
    {
        "id": "REQUEST_BOT_MATRIX_SERVER",
        "type": "matrix-server-config",
        "name": "MATRIX_SERVER",
        "autoAcceptRoomInvites": false,
        "enableE2ee": true,
        "global": true,
        "allowUnknownDevices": false
    },
