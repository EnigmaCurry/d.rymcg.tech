        "type": "function",
        "z": "REQUEST_BOT_TAB_REACTIONS",
        "name": "Reply to NATS",
        "func": "// Matrix React preserves msg._reply; Matrix Delete does not\nvar replyTo = msg._reply;\nif (!replyTo) { return null; }\nmsg.topic = replyTo;\nmsg.payload = msg.eventId || '';\nreturn msg;",
