        ]
    },
    {
        "id": "REQUEST_BOT_FN_FORMAT_MESSAGE",
        "type": "function",
        "z": "REQUEST_BOT_TAB_MESSAGES",
        "name": "Format for NATS",
        "func": "msg.payload = JSON.stringify({\n    userId: msg.userId,\n    topic: msg.topic,\n    eventId: msg.eventId,\n    content: msg.content\n});\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 200,
