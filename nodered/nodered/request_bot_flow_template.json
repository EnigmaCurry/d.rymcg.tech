    },
    {
        "id": "REQUEST_BOT_FN_AFTER_SEND",
        "type": "function",
        "z": "REQUEST_BOT_TAB_RESPONSES",
        "name": "Reply to NATS",
        "func": "// Retrieve NATS reply subject from global context\nvar replyTo = global.get('nats_reply_' + msg.topic);\nglobal.set('nats_reply_' + msg.topic, null);\nif (!replyTo) { return null; }\nmsg.topic = replyTo;\nmsg.payload = msg.eventId;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 200,
        "wires": [
