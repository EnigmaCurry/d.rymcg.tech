#!/bin/bash

## llama-manage-model-configs SERVICE [ENV_FILE]
## Interactive editor for per-model INI configuration sections.
## Uses /models/models.ini as the single preset file for all models.
## The server reads this file at startup via --models-preset.

BIN=$(dirname ${BASH_SOURCE})
ROOT_DIR="${ROOT_DIR:-$(dirname ${BIN})}"
source ${ROOT_DIR}/_scripts/funcs.sh
set -eo pipefail

SERVICE="${1}"
ENV_FILE="${2:-}"

if [[ -z "${SERVICE}" ]]; then
    fault "Usage: llama-manage-model-configs SERVICE [ENV_FILE]"
fi

COMPOSE="docker compose"
if [[ -n "${ENV_FILE}" ]]; then
    COMPOSE="docker compose --env-file ${ENV_FILE}"
    DOTENV="${BIN}/dotenv -f ${ENV_FILE} get"
else
    DOTENV="${BIN}/dotenv get"
fi

# Get models_preset_enabled
MODELS_PRESET_ENABLED=$(${DOTENV} LLAMA_MODELS_PRESET_ENABLED 2>/dev/null || echo "true")
if [[ "${MODELS_PRESET_ENABLED}" != "true" ]]; then
    echo "Models preset is disabled (LLAMA_MODELS_PRESET_ENABLED=${MODELS_PRESET_ENABLED})."
    echo "Enable it in the .env file to manage model configurations via INI."
    exit 0
fi

# Get .env defaults for template
ENV_N_GPU_LAYERS=$(${DOTENV} LLAMA_N_GPU_LAYERS 2>/dev/null || true)
ENV_CONTEXT_LENGTH=$(${DOTENV} LLAMA_CONTEXT_LENGTH 2>/dev/null || true)

# Default values if .env is blank
DEFAULT_THREADS=8
DEFAULT_GPU_LAYERS="${ENV_N_GPU_LAYERS:-99}"
DEFAULT_CONTEXT="${ENV_CONTEXT_LENGTH:-8192}"

# Get list of .gguf files
readarray -t models < <(${COMPOSE} exec -T "${SERVICE}" bash -c '
    shopt -s nullglob
    files=(/models/*.gguf)
    if [[ ${#files[@]} -gt 0 ]]; then
        for f in "${files[@]}"; do
            size=$(stat -c%s "$f" 2>/dev/null || echo 0)
            human=$(numfmt --to=iec-i --suffix=B "$size" 2>/dev/null || echo "$size bytes")
            echo "$(basename "$f") (${human})"
        done
    fi
')

if [[ ${#models[@]} -eq 0 ]]; then
    echo "No .gguf models found in /models/."
    exit 0
fi

# Check if models.ini exists
INI_EXISTS=$(${COMPOSE} exec -T "${SERVICE}" test -f "/models/models.ini" && echo "yes" || echo "no")

echo "=== Manage Model Configurations (models.ini) ==="
echo ""

# Use script-wizard choose for single selection
selected=$(wizard choose "Select a model to configure:" "${models[@]}")

if [[ -z "${selected}" ]]; then
    echo "No selection made. Exiting."
    exit 0
fi

# Extract just the filename (before the size info in parens)
model_filename=$(echo "${selected}" | sed 's/ (.*$//')
model_id="${model_filename%.gguf}"

# Download models.ini if it exists, otherwise create blank
TMPDIR=$(mktemp -d)
trap "rm -rf ${TMPDIR}" EXIT

LOCAL_INI="${TMPDIR}/models.ini"

if [[ "${INI_EXISTS}" == "yes" ]]; then
    echo "Downloading models.ini..."
    ${COMPOSE} exec -T "${SERVICE}" cp "/models/models.ini" "/tmp/models.ini" 2>/dev/null || true
    ${COMPOSE} cp "${SERVICE}:/tmp/models.ini" "${LOCAL_INI}" 2>/dev/null || \
    ${COMPOSE} exec -T "${SERVICE}" cat "/tmp/models.ini" > "${LOCAL_INI}"
    ${COMPOSE} exec -T "${SERVICE}" bash -c "rm -f /tmp/models.ini" 2>/dev/null || true
    echo "Existing models.ini downloaded for editing."
else
    echo "No models.ini found. Creating new file..."
    touch "${LOCAL_INI}"
fi

# Check if this model already has a section
HAS_SECTION=$(${COMPOSE} exec -T "${SERVICE}" python3 -c "
import configparser
c = configparser.ConfigParser()
c.read('/models/models.ini')
print('yes' if '${model_id}' in c.sections() else 'no')
" 2>/dev/null || echo "no")

if [[ "${HAS_SECTION}" == "no" ]]; then
    echo ""
    echo "Model '${model_filename}' has no configuration section yet."
    echo "A new section will be created with default values from your .env file."
    echo ""
fi

echo ""
echo "Opening models.ini in ${EDITOR:-nano}..."
echo ""

${EDITOR} "${LOCAL_INI}"

# Upload the INI back to the container
echo ""
echo "Uploading models.ini to /models/..."
${COMPOSE} exec -T "${SERVICE}" bash -c "cat > /models/models.ini" < "${LOCAL_INI}"

# Validate INI syntax using Python configparser
echo ""
echo "Validating INI syntax..."
INI_VALID=$(${COMPOSE} exec -T "${SERVICE}" python3 -c "
import configparser
c = configparser.ConfigParser()
try:
    c.read('/models/models.ini')
    print('valid')
except Exception as e:
    print('invalid: ' + str(e))
" 2>/dev/null || echo "invalid: python3 not available")

if [[ "${INI_VALID}" != "valid" ]]; then
    rm -f "${LOCAL_INI}" 2>/dev/null || true
    ${COMPOSE} exec -T "${SERVICE}" bash -c "rm -f /models/models.ini" 2>/dev/null || true
    fault "Invalid INI syntax. The file was not saved. Please fix the INI and try again."
fi

echo "models.ini saved to /models/models.ini in the container."

echo ""
echo "NOTE: llama.cpp reads the preset file at startup."
echo "You must restart the service for changes to take effect:"
echo "  make restart"
echo ""
echo "Done."
