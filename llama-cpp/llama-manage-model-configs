#!/bin/bash

## llama-manage-model-configs SERVICE [ENV_FILE]
## Interactive editor for per-model INI configuration sections.
## Uses /models/models.ini as the single preset file for all models.
## The server reads this file at startup via --models-preset.
##
## Flow: download → edit → validate locally → upload if valid

set -eo pipefail

SERVICE="${1}"
ENV_FILE="${2:-}"

if [[ -z "${SERVICE}" ]]; then
    echo "Usage: llama-manage-model-configs SERVICE [ENV_FILE]" >&2
    exit 1
fi

COMPOSE="docker compose"
if [[ -n "${ENV_FILE}" ]]; then
    COMPOSE="docker compose --env-file ${ENV_FILE}"
    DOTENV="${DOTENV_CMD:-dotenv} -f ${ENV_FILE} get"
else
    DOTENV="${DOTENV_CMD:-dotenv} get"
fi

# Get models_preset_enabled
MODELS_PRESET_ENABLED=$(${DOTENV} LLAMA_MODELS_PRESET_ENABLED 2>/dev/null || echo "true")
if [[ "${MODELS_PRESET_ENABLED}" != "true" ]]; then
    echo "Models preset is disabled (LLAMA_MODELS_PRESET_ENABLED=${MODELS_PRESET_ENABLED})."
    echo "Enable it in the .env file to manage model configurations via INI."
    exit 0
fi

TMPDIR=$(mktemp -d)
trap "rm -rf ${TMPDIR}" EXIT

LOCAL_INI="${TMPDIR}/models.ini"

# Download models.ini if it exists, otherwise create with commented example
INI_EXISTS=$(${COMPOSE} exec -T "${SERVICE}" test -f "/models/models.ini" && echo "yes" || echo "no")

if [[ "${INI_EXISTS}" == "yes" ]]; then
    echo "Downloading models.ini..."
    ${COMPOSE} exec -T "${SERVICE}" cp "/models/models.ini" "/tmp/models.ini" 2>/dev/null || true
    ${COMPOSE} cp "${SERVICE}:/tmp/models.ini" "${LOCAL_INI}" 2>/dev/null || \
    ${COMPOSE} exec -T "${SERVICE}" cat "/tmp/models.ini" > "${LOCAL_INI}"
    ${COMPOSE} exec -T "${SERVICE}" bash -c "rm -f /tmp/models.ini" 2>/dev/null || true
    echo "Existing models.ini downloaded for editing."
else
    echo "No models.ini found. Creating new file with example sections..."
    ENV_N_GPU_LAYERS=$(${DOTENV} LLAMA_N_GPU_LAYERS 2>/dev/null || true)
    ENV_CONTEXT_LENGTH=$(${DOTENV} LLAMA_CONTEXT_LENGTH 2>/dev/null || true)
    DEFAULT_N_GPU_LAYERS="${ENV_N_GPU_LAYERS:-99}"
    DEFAULT_CONTEXT_LENGTH="${ENV_CONTEXT_LENGTH:-8192}"
    cat > "${LOCAL_INI}" <<EOF
# Per-model configuration for llama.cpp
# Each section is a model display name; the 'model' key points to the .gguf file.
#
# [llama3]
# model = /models/llama-3-8b-instruct.Q5_K_M.gguf
# ctx-size = ${DEFAULT_CONTEXT_LENGTH}
# ngl = ${DEFAULT_N_GPU_LAYERS}
# threads = 8

[mistral]
model = /models/mistral-7b-instruct-v0.3.Q4_K_M.gguf
ctx-size = ${DEFAULT_CONTEXT_LENGTH}
ngl = ${DEFAULT_N_GPU_LAYERS}
threads = 8
EOF
fi

# Open in editor
echo ""
echo "Opening models.ini in ${EDITOR:-nano}..."
echo ""
${EDITOR} "${LOCAL_INI}"

# Validate locally with python3 configparser
echo ""
echo "Validating INI syntax..."

PYTHON3_VALID=true
if ! command -v python3 &>/dev/null; then
    PYTHON3_VALID=false
elif ! python3 -c "import configparser" 2>/dev/null; then
    PYTHON3_VALID=false
fi

if [[ "${PYTHON3_VALID}" == "true" ]]; then
    VALID_OUTPUT=$(python3 -c "
import configparser, sys
c = configparser.ConfigParser()
try:
    c.read('${LOCAL_INI}')
    print('valid')
except Exception as e:
    print('invalid: ' + str(e))
" 2>/dev/null) || VALID_OUTPUT="invalid: python3 returned an error"
else
    VALID_OUTPUT=""
fi

if [[ -n "${VALID_OUTPUT}" && "${VALID_OUTPUT}" != "valid" ]]; then
    echo ""
    echo "Invalid INI syntax. Upload aborted — the existing container file is untouched."
    echo "Error: ${VALID_OUTPUT}"
    echo ""

    while true; do
        echo "The INI file will re-open in your editor in 5 seconds to fix the errors."
        echo "Press N and then Enter to abort entirely."
        if read -t 5 -rn 1 -p "> " ANSWER; then
            echo ""
            if [[ "${ANSWER}" == "N" || "${ANSWER}" == "n" ]]; then
                echo "Aborted."
                exit 1
            fi
        else
            echo ""
        fi

        echo ""
        echo "Re-opening models.ini in ${EDITOR:-nano}..."
        echo ""
        ${EDITOR} "${LOCAL_INI}"

        echo ""
        echo "Re-validating INI syntax..."

        if [[ "${PYTHON3_VALID}" == "true" ]]; then
            VALID_OUTPUT=$(python3 -c "
import configparser, sys
c = configparser.ConfigParser()
try:
    c.read('${LOCAL_INI}')
    print('valid')
except Exception as e:
    print('invalid: ' + str(e))
" 2>/dev/null) || VALID_OUTPUT="invalid: python3 returned an error"
        else
            VALID_OUTPUT=""
        fi

        if [[ -z "${VALID_OUTPUT}" || "${VALID_OUTPUT}" == "valid" ]]; then
            break
        fi

        echo ""
        echo "Invalid INI syntax. Upload aborted — the existing container file is untouched."
        echo "Error: ${VALID_OUTPUT}"
        echo ""
    done
fi

# Upload to container
COMPOSE_CMD="docker compose"
if [[ -n "${ENV_FILE}" ]]; then
    COMPOSE_CMD="docker compose --env-file ${ENV_FILE}"
fi

echo "Uploading models.ini to /models/..."
${COMPOSE} exec -T "${SERVICE}" bash -c "cat > /models/models.ini" < "${LOCAL_INI}"

echo "models.ini saved to /models/models.ini in the container."

echo ""
echo "NOTE: llama.cpp reads the preset file at startup."
echo "You must restart the service for changes to take effect:"
echo "  make restart"
echo ""
echo "Done."
