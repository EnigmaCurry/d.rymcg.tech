# Resolve context, decrypt SOPS config, extract BAO vars, prepare container run args.
# Sets: _BAO_RUN_ARGS (array for engine run), _BAO_CTX (array for --context default).
_bao_resolve() {
    local wizard_prompt="$1"
    check_engine

    if [[ -z "${_BAO_CONTEXT}" ]]; then
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .sops.env)")
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "No configs found. Run 'drt --init' first." >&2
            exit 1
        fi
        _BAO_CONTEXT=$(wizard choose "${wizard_prompt}" "${CONTEXTS[@]}")
    fi

    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${_BAO_CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    local AGE_KEY_FILE="${_BAO_AGE_KEY_FILE}"
    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${_BAO_CONTEXT}.key"
    fi
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key not found: ${AGE_KEY_FILE}" >&2
        exit 1
    fi

    # Decrypt passphrase-protected AGE key
    local DEC_DIR=""
    if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
        DEC_DIR=$(mktemp -d)
        cp "${AGE_KEY_FILE}" "${DEC_DIR}/age-key-in"
        echo "## Get ready to enter your AGE key passphrase ..." >&2
        container_run -it --user 0:0 \
            -v "${DEC_DIR}:/tmp/age-work:Z" \
            "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-work/age-key-dec'
        echo "## Passphrase accepted." >&2
        AGE_KEY_FILE="${DEC_DIR}/age-key-dec"
    fi

    # Decrypt SOPS config
    local PLAINTEXT
    PLAINTEXT=$(container_run \
        --user 0:0 -i \
        -v "${SOPS_CONFIG}:/tmp/config.sops.env:ro" \
        -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
        -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
        "${IMAGE}" \
        sops decrypt --input-type dotenv --output-type dotenv \
            --filename-override export.env /tmp/config.sops.env)

    [[ -n "${DEC_DIR}" ]] && rm -rf "${DEC_DIR}"

    local BAO_ADDR=""
    BAO_ADDR=$(echo "${PLAINTEXT}" | grep -oP '^BAO_ADDR=\K.*' || true)
    if [[ -z "${BAO_ADDR}" ]]; then
        echo "Error: BAO_ADDR not found in ${_BAO_CONTEXT} config — OpenBao is not configured for this context." >&2
        exit 1
    fi
    echo "## OpenBao server: ${BAO_ADDR}" >&2

    # Build env vars for the container
    local BAO_ENV=()
    local var
    local _has_cacert=false _has_client_cert=false
    for var in BAO_ADDR BAO_CACERT BAO_CLIENT_CERT BAO_CLIENT_KEY; do
        local val=""
        val=$(echo "${PLAINTEXT}" | grep -oP "^${var}=\\K.*" || true)
        if [[ -n "${val}" ]]; then
            BAO_ENV+=(-e "${var}=${val}")
            [[ "${var}" == "BAO_CACERT" ]] && _has_cacert=true
            [[ "${var}" == "BAO_CLIENT_CERT" ]] && _has_client_cert=true
        fi
    done
    if [[ "${_has_client_cert}" == "true" ]]; then
        echo "## TLS: mTLS (client certificate + CA)" >&2
    elif [[ "${_has_cacert}" == "true" ]]; then
        echo "## TLS: custom CA certificate" >&2
    fi

    detect_net_mode
    _BAO_RUN_ARGS=(run --rm -it --entrypoint "")
    [[ -n "${NET_MODE}" ]] && _BAO_RUN_ARGS+=(--net="${NET_MODE}")
    _BAO_RUN_ARGS+=("${BAO_ENV[@]}" "${IMAGE}")

    _BAO_CTX=()
    if [[ "${ENGINE}" == "docker" ]]; then
        _BAO_CTX=(--context default)
    fi
}

# Inline TLS resolution script (sourced inside the container)
_BAO_TLS_SCRIPT='
TLS_FLAGS=()
_resolve_tls() {
    local var="$1" flag="$2" val="${!1:-}"
    [ -z "${val}" ] && return
    local f="/tmp/tls-${var}"
    if [ -f "${val}" ]; then
        f="${val}"
    elif echo "${val}" | grep -q "BEGIN"; then
        echo "${val}" > "${f}"
    elif [ ${#val} -gt 60 ] && echo "${val}" | grep -qE "^[A-Za-z0-9+/=]+$"; then
        echo "${val}" | base64 -d > "${f}"
    else
        echo "${val}" > "${f}"
    fi
    TLS_FLAGS+=("${flag}" "${f}")
}
_resolve_tls BAO_CACERT --cacert
_resolve_tls BAO_CLIENT_CERT --cert
_resolve_tls BAO_CLIENT_KEY --key
'

###############################################################################
# seal subcommand
###############################################################################

cmd_seal() {
    _bao_parse_args seal "$@"
    _bao_resolve "Select context to seal"

    "${ENGINE}" "${_BAO_CTX[@]}" "${_BAO_RUN_ARGS[@]}" bash -c '
set -eo pipefail
'"${_BAO_TLS_SCRIPT}"'

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
if [ -z "${STATUS}" ]; then
    echo "Error: could not reach ${BAO_ADDR}" >&2
    exit 1
fi

SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "true" ]; then
    echo "## OpenBao at ${BAO_ADDR} is already sealed." >&2
    exit 0
fi

printf "Seal the OpenBao server at %s? [y/N] " "${BAO_ADDR}" >&2
read -r answer < /dev/tty
case "${answer}" in
    [Yy]*) ;;
    *) echo "## Cancelled" >&2; exit 0 ;;
esac

printf "Root token: " >&2
read -rs ROOT_TOKEN < /dev/tty
echo "" >&2

curl -sf "${TLS_FLAGS[@]}" -X PUT \
    -H "X-Vault-Token: ${ROOT_TOKEN}" \
    "${BAO_ADDR}/v1/sys/seal" >/dev/null 2>&1 || true

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "true" ]; then
    echo "## OpenBao at ${BAO_ADDR} has been sealed." >&2
else
    echo "Error: seal failed. Check the root token and try again." >&2
    exit 1
fi'
}

###############################################################################
# unseal subcommand
###############################################################################

cmd_unseal() {
    _bao_parse_args unseal "$@"
    _bao_resolve "Select context to unseal"

    "${ENGINE}" "${_BAO_CTX[@]}" "${_BAO_RUN_ARGS[@]}" bash -c '
set -eo pipefail
'"${_BAO_TLS_SCRIPT}"'

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
if [ -z "${STATUS}" ]; then
    echo "Error: could not reach ${BAO_ADDR}" >&2
    exit 1
fi

SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "false" ]; then
    echo "## OpenBao at ${BAO_ADDR} is already unsealed." >&2
    exit 0
fi

THRESHOLD=$(echo "${STATUS}" | jq -r .t)
TOTAL=$(echo "${STATUS}" | jq -r .n)
PROGRESS=$(echo "${STATUS}" | jq -r .progress)
echo "## Unseal requires ${THRESHOLD} of ${TOTAL} keys (${PROGRESS} already provided)" >&2

while true; do
    STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
    SEALED=$(echo "${STATUS}" | jq -r .sealed)
    PROGRESS=$(echo "${STATUS}" | jq -r .progress)

    if [ "${SEALED}" = "false" ]; then
        echo "## OpenBao at ${BAO_ADDR} has been unsealed." >&2
        exit 0
    fi

    printf "Unseal key (%s/%s): " "$((PROGRESS + 1))" "${THRESHOLD}" >&2
    read -rs UNSEAL_KEY < /dev/tty
    echo "" >&2

    RESPONSE=$(curl -sf "${TLS_FLAGS[@]}" -X PUT \
        --data "{\"key\":\"${UNSEAL_KEY}\"}" \
        "${BAO_ADDR}/v1/sys/unseal" 2>/dev/null || true)

    if [ -z "${RESPONSE}" ]; then
        echo "Error: unseal request failed" >&2
        exit 1
    fi

    SEALED=$(echo "${RESPONSE}" | jq -r .sealed)
    PROGRESS=$(echo "${RESPONSE}" | jq -r .progress)

    if [ "${SEALED}" = "false" ]; then
        echo "## OpenBao at ${BAO_ADDR} has been unsealed." >&2
        exit 0
    fi

    echo "## Progress: ${PROGRESS}/${THRESHOLD}" >&2
done'
}

###############################################################################
# extract subcommand
###############################################################################

cmd_extract() {
    if [[ -n "${DRT_IMAGE:-}" ]]; then
        sed "s|@@DRT_IMAGE@@|${DRT_IMAGE}|g" "$(readlink -f "$0")"
    else
        cat "$(readlink -f "$0")"
    fi
}

###############################################################################
# Main dispatch
###############################################################################

ACTION=run
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --init)
            ACTION=init
            shift
            ARGS+=("$@")
            break
            ;;
        --view)
            ACTION=view
            shift
            ARGS+=("$@")
            break
            ;;
        --edit)
            ACTION=edit
            shift
            ARGS+=("$@")
            break
            ;;
        --clean)
            ACTION=clean
            shift
            ARGS+=("$@")
            break
            ;;
        --seal)
            ACTION=seal
            shift
            ARGS+=("$@")
            break
            ;;
        --unseal)
            ACTION=unseal
            shift
            ARGS+=("$@")
            break
            ;;
        --pull)
            ACTION=pull
            shift
            ;;
        --build)
            ACTION=build
            shift
            # Consume optional trailing args (e.g. context) — ignored for build
            while [[ $# -gt 0 ]]; do shift; done
            ;;
        --list)
            ACTION=list
            shift
            ;;
        --git-init)
            ACTION=git_init
            shift
            ;;
        --git)
            ACTION=git
            shift
            ARGS=("$@")
            break
            ;;
        --extract)
            ACTION=extract
            shift
            ;;
        --image)
            IMAGE="$2"
            ARGS+=(--image "$2")
            shift 2
            ;;
        --docker)
            ENGINE=docker
            ARGS+=(--docker)
            shift
            ;;
        --net)
            NET_MODE="$2"
            ARGS+=(--net "$2")
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "drt ${VERSION}"
            exit 0
            ;;
        -*)
            # Pass through to cmd_run
            ARGS+=("$1")
            shift
            ;;
        *)
            # Positional arg = CONTEXT for run; check remaining args for action flags
            ARGS+=("$1")
            shift
            # Scan remaining args: if an action flag appears, switch to that action
            for _remaining in "$@"; do
                case "${_remaining}" in
                    --init)   ACTION=init; break ;;
                    --view)   ACTION=view; break ;;
                    --edit)   ACTION=edit; break ;;
                    --clean)  ACTION=clean; break ;;
                    --seal)   ACTION=seal; break ;;
                    --unseal) ACTION=unseal; break ;;
                esac
            done
            if [[ "${ACTION}" != "run" ]]; then
                # Re-parse remaining args into ARGS (context already added)
                for _remaining in "$@"; do
                    [[ "${_remaining}" == "--${ACTION}" ]] && continue
                    ARGS+=("${_remaining}")
                done
            else
                ARGS+=("$@")
            fi
            break
            ;;
    esac
done

case "${ACTION}" in
    init)
        cmd_init "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    view)
        cmd_view "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    edit)
        cmd_edit "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    clean)
        cmd_clean "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    seal)
        cmd_seal "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    unseal)
        cmd_unseal "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    pull)
        cmd_pull
        ;;
    build)
        cmd_build "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    list)
        cmd_list
        ;;
    git_init)
        cmd_git_init
        ;;
    git)
        cmd_git "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    extract)
        cmd_extract
        ;;
    run)
        if [[ ${#ARGS[@]} -eq 0 ]]; then
            check_engine
            echo "Run with --help to see full usage." >&2
            echo "" >&2
            _CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
            _KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
            _CHOICES=()
            if [[ -d "${_CONFIG_DIR}" ]]; then
                for f in "${_CONFIG_DIR}"/*.sops.env; do
                    [[ -f "$f" ]] || continue
                    _name="$(basename "$f" .sops.env)"
                    _key_status="no key"
                    if [[ -f "${_KEY_DIR}/${_name}.key" ]]; then
                        if head -1 "${_KEY_DIR}/${_name}.key" | grep -q '^age-encryption.org'; then
                            _key_status="encrypted key"
                        else
                            _key_status="plain-text key!!"
                        fi
                    fi
                    _CHOICES+=("${_name} (${_key_status}; ${f})")
                done
            fi
            if [[ ${#_CHOICES[@]} -eq 0 ]]; then
                echo "No configs found. Run 'drt --init' first." >&2
                exit 1
            fi
            _CHOICE=$(wizard choose "Select context to load" "${_CHOICES[@]}")
            ARGS+=("${_CHOICE%% *}")
        fi
        cmd_run "${ARGS[@]}"
        ;;
esac

###############################################################################
# How to setup the 'drt' alias for d.rymcg.tech:
# (Do this on your host workstation)
#
# Define a shell alias (add to ~/.bashrc or ~/.zshrc):
#
#   alias drt='bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt)'
#
# When you run e.g. "drt --init myserver", bash expands this to:
#
#   bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt) --init myserver
#
# The container entrypoint detects "drt" with no args and runs "drt --extract",
# which prints this script to stdout. The process substitution feeds it to
# bash, which executes it with the remaining arguments (--init myserver).
#
# The script itself never touches the container — it runs entirely on the
# host, orchestrating podman/docker to launch containers as needed.
#
# Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
###############################################################################
