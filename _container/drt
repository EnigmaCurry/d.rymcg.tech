view_usage() {
    cat <<'EOF'
Usage: drt --view [OPTIONS] [CONTEXT_NAME]

Decrypt and display a SOPS config file.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --age-key FILE AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --help         Show this help
EOF
}

cmd_view() {
    local CONTEXT="" AGE_KEY_FILE=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --age-key) AGE_KEY_FILE="$2"; shift 2 ;;
            --help) view_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                view_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    view_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine
    git_auto_pull

    ## Pick context interactively if not provided
    if [[ -z "${CONTEXT}" ]]; then
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .sops.env)")
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "No configs found. Run 'drt --init' first." >&2
            exit 1
        fi
        CONTEXT=$(wizard choose "Select context to view" "${CONTEXTS[@]}")
    fi

    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    fi
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key not found: ${AGE_KEY_FILE}" >&2
        exit 1
    fi

    # Decrypt and view — if AGE key is passphrase-protected, decrypt + sops in one container run
    local PLAINTEXT
    if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
        local _VIEW_DIR
        _VIEW_DIR=$(mktemp -d)
        cp "${AGE_KEY_FILE}" "${_VIEW_DIR}/age-key-in"
        cp "${SOPS_CONFIG}" "${_VIEW_DIR}/config.sops.env"
        echo "## Get ready to enter your AGE key passphrase ..." >&2
        container_run -it --user 0:0 \
            -v "${_VIEW_DIR}:/tmp/view-work:Z" \
            "${IMAGE}" sh -c 'age -d /tmp/view-work/age-key-in > /tmp/age-key-dec && \
                SOPS_AGE_KEY_FILE=/tmp/age-key-dec sops decrypt \
                --input-type dotenv --output-type dotenv \
                --filename-override export.env /tmp/view-work/config.sops.env \
                > /tmp/view-work/config-decrypted && \
                chmod 644 /tmp/view-work/config-decrypted'
        echo "## Passphrase accepted." >&2
        PLAINTEXT=$(cat "${_VIEW_DIR}/config-decrypted")
        rm -rf "${_VIEW_DIR}"
    else
        PLAINTEXT=$(container_run \
            --user 0:0 -i \
            -v "${SOPS_CONFIG}:/tmp/config.sops.env:ro" \
            -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
            -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
            "${IMAGE}" \
            sops decrypt --input-type dotenv --output-type dotenv \
                --filename-override export.env /tmp/config.sops.env)
    fi

    if [[ -t 1 ]]; then
        echo "${PLAINTEXT}" | less
    else
        echo "${PLAINTEXT}"
    fi
}

