#!/usr/bin/env bash
## drt — standalone d-rymcg-tech bootstrap tool
## Combines init + run into a single script with no repo dependency.
## Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
## Setup alias:
##   alias drt='bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt)'
set -euo pipefail

VERSION="1.0.0"
DEFAULT_IMAGE="${DRT_IMAGE:-@@DRT_IMAGE@@}"
if [[ "${DEFAULT_IMAGE}" == @@*@@ ]]; then
    DEFAULT_IMAGE="localhost/d-rymcg-tech:latest"
fi

###############################################################################
# Shared helpers
###############################################################################

ENGINE=podman
IMAGE="${DEFAULT_IMAGE}"
BUILD=false

check_engine() {
    if ! command -v "${ENGINE}" &>/dev/null; then
        echo "Error: ${ENGINE} not found in PATH" >&2
        echo "Install ${ENGINE} first, or use --docker to use Docker instead." >&2
        exit 1
    fi
}

## Run a command inside the container, bypassing the entrypoint
## Always runs locally (--context default for docker) to avoid executing on a remote SSH context
container_run() {
    if [[ "${ENGINE}" == "docker" ]]; then
        "${ENGINE}" --context default run --rm --entrypoint "" "$@"
    else
        "${ENGINE}" run --rm --entrypoint "" "$@"
    fi
}

## Run script-wizard inside the container interactively
## Uses a named container so we can copy the answer out after it exits
wizard() {
    local cname="wizard-$$-${RANDOM}"
    local answer="/tmp/wizard-answer-${cname}"
    local _ctx=()
    [[ "${ENGINE}" == "docker" ]] && _ctx=(--context default)
    trap '"${ENGINE}" "${_ctx[@]}" rm "${cname}" >/dev/null 2>&1' EXIT
    "${ENGINE}" "${_ctx[@]}" run -it --name "${cname}" --entrypoint "" \
        -e "TERM=${TERM:-xterm}" -e "WIZARD_ANSWER=${answer}" \
        "${IMAGE}" \
        sh -c 'script-wizard "$@" > "${WIZARD_ANSWER}"' -- "$@" >&2
    local rc=$?
    "${ENGINE}" "${_ctx[@]}" cp "${cname}:${answer}" - | tar -xO
    trap - EXIT
    "${ENGINE}" "${_ctx[@]}" rm "${cname}" >/dev/null
    return $rc
}

###############################################################################
# Top-level usage
###############################################################################

usage() {
    cat <<'EOF'
drt — standalone d-rymcg-tech bootstrap tool

Usage:
  drt [OPTIONS] CONTEXT [CMD]  Launch container (interactive shell or run CMD)

Options:
  --init [CONTEXT]   Bootstrap AGE key + SOPS config for a context
  --view [CONTEXT]   Decrypt and display SOPS config
  --clean [CONTEXT]  Remove SOPS config and/or AGE key for a context
  --list             List all contexts (AGE keys and SOPS configs)
  --extract          Print this script to stdout (self-extraction)
  --image TAG        Container image (default: localhost/d-rymcg-tech:latest)
  --docker           Use Docker instead of Podman
  --age-key FILE     AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --ssh-key FILE     SSH key file (disables agent forwarding)
  --ssh-timeout SEC  SSH ConnectTimeout in seconds (default: 30)
  --timeout SEC      Command timeout in seconds (default: 300)
  --no-save          Disable save-on-exit
  --controller-port PORT  Host port for request-controller (default: 8084)
  --version          Print version
  --help             Show this help
EOF
    echo ""
    echo "One time setup:"
    if [[ "${IMAGE}" != localhost/* ]]; then
        echo "  ${ENGINE} pull ${IMAGE}"
    fi
    echo "  alias drt='bash <(${ENGINE} run --rm --pull=never ${IMAGE} drt)'"
}

###############################################################################
# init subcommand
###############################################################################

init_usage() {
    cat <<'EOF'
Usage: drt --init [OPTIONS] [CONTEXT_NAME]

Bootstrap a new d-rymcg-tech deployment config.

Generates an AGE encryption key (if needed) and creates a SOPS-encrypted
config file for the given context. Only requires Podman (or Docker).

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_init() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) init_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                init_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    init_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine

    ## Context name
    if [[ -z "${CONTEXT}" ]]; then
        CONTEXT=$(wizard ask "Enter the context name (SSH host alias)")
    fi

    ## Check for existing config
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
        echo "Config already exists: ${CONFIG_DIR}/${CONTEXT}.sops.env"
        echo ""
        echo "To modify it interactively, run:"
        echo "  drt ${CONTEXT}"
        exit 0
    fi

    ## Ensure AGE key (one per context)
    local AGE_KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local AGE_KEY_FILE="${AGE_KEY_DIR}/${CONTEXT}.key"
    local PUBKEY
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "No AGE key found for context '${CONTEXT}'"
        echo "Generating a new AGE keypair..."
        mkdir -p "${AGE_KEY_DIR}"
        container_run "${IMAGE}" age-keygen > "${AGE_KEY_FILE}"
        chmod 600 "${AGE_KEY_FILE}"

        ## Extract public key while file is still plaintext
        PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)

        ## Optional passphrase protection
        if wizard confirm "Password-protect the AGE key?" yes; then
            local ENC_DIR
            ENC_DIR=$(mktemp -d)
            cp "${AGE_KEY_FILE}" "${ENC_DIR}/age-key-in"
            local ENCRYPTED="${ENC_DIR}/age-key-enc"
            if container_run -it --user 0:0 \
                -v "${ENC_DIR}:/tmp/age-work:Z" \
                "${IMAGE}" sh -c 'age -p /tmp/age-work/age-key-in > /tmp/age-work/age-key-enc' \
                && [[ -s "${ENCRYPTED}" ]]; then
                mv "${ENCRYPTED}" "${AGE_KEY_FILE}"
                chmod 600 "${AGE_KEY_FILE}"
                echo "AGE key created (passphrase-protected): ${AGE_KEY_FILE}"
            else
                rm -f "${ENCRYPTED}" "${AGE_KEY_FILE}"
                echo "Error: passphrase encryption failed — no key was saved." >&2
                exit 1
            fi
        else
            echo "AGE key created: ${AGE_KEY_FILE}"
        fi
    else
        echo "Using existing AGE key: ${AGE_KEY_FILE}"
        ## Extract public key — if encrypted, need to decrypt first
        if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
            local DEC_DIR
            DEC_DIR=$(mktemp -d)
            cp "${AGE_KEY_FILE}" "${DEC_DIR}/age-key-in"
            container_run -it --user 0:0 \
                -v "${DEC_DIR}:/tmp/age-work:Z" \
                "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-work/age-key-dec'
            PUBKEY=$(grep -o 'age1[a-z0-9]*' "${DEC_DIR}/age-key-dec" | head -1)
            rm -rf "${DEC_DIR}"
        else
            PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)
            echo "WARNING: AGE key is NOT password-protected."
        fi
    fi
    echo "AGE public key: ${PUBKEY}"
    echo ""

    ## SSH details — pre-fill from ssh config if available
    local SSH_CONFIG SSH_HOST SSH_PORT SSH_USER
    SSH_CONFIG=$(ssh -G "${CONTEXT}" 2>/dev/null || true)
    local _SSH_HOST _SSH_PORT _SSH_USER
    _SSH_HOST=$(echo "${SSH_CONFIG}" | awk '/^hostname / {print $2}')
    _SSH_PORT=$(echo "${SSH_CONFIG}" | awk '/^port / {print $2; exit}')
    _SSH_USER=$(echo "${SSH_CONFIG}" | awk '/^user / {print $2}')

    SSH_HOST=$(wizard ask "Enter SSH host" "${_SSH_HOST}")
    SSH_PORT=$(wizard ask "Enter SSH port" "${_SSH_PORT:-22}")
    SSH_USER=$(wizard ask "Enter SSH user" "${_SSH_USER:-root}")

    ## SSH key scan
    local KNOWN_HOSTS=""
    if wizard confirm "Run ssh-keyscan now for ${SSH_HOST}:${SSH_PORT}?" yes; then
        echo ""
        echo "Running ssh-keyscan for ${SSH_HOST}:${SSH_PORT}..."
        KNOWN_HOSTS=$(ssh-keyscan -p "${SSH_PORT}" "${SSH_HOST}" 2>/dev/null || true)
    fi
    if [[ -z "${KNOWN_HOSTS}" ]]; then
        echo "WARNING: ssh-keyscan failed for ${SSH_HOST}:${SSH_PORT}"
        echo "  You can set SSH_KNOWN_HOSTS later, or set SSH_KEY_SCAN=false to skip verification."
    else
        echo "SSH host keys collected."
    fi

    ## Optional OpenBao SSH certificate signing
    local BAO_ADDR="" BAO_ROLE_ID="" BAO_SECRET_ID="" BAO_SSH_MOUNT="" BAO_SSH_ROLE=""
    local BAO_AUTH_PATH="" BAO_AGE_KEY_PATH="" BAO_KV_MOUNT="" BAO_NAMESPACE=""
    local BAO_CACERT="" BAO_CLIENT_CERT="" BAO_CLIENT_KEY=""
    if wizard confirm "Configure OpenBao SSH certificate signing?" no; then
        BAO_ADDR=$(wizard ask "Enter OpenBao server URL (e.g., https://bao.example.com:443)")
        BAO_ROLE_ID=$(wizard ask "Enter OpenBao BAO_ROLE_ID")
        BAO_SECRET_ID=$(wizard ask "Enter OpenBao BAO_SECRET_ID")
        BAO_SSH_MOUNT=$(wizard ask "Enter SSH engine mount" "ssh-client-signer")
        BAO_SSH_ROLE=$(wizard ask "Enter SSH signing role" "woodpecker-short-lived")
        BAO_AUTH_PATH=$(wizard ask "Enter auth path" "auth/approle")

        if wizard confirm "Retrieve AGE key from OpenBao KV?" no; then
            BAO_AGE_KEY_PATH=$(wizard ask "Enter KV path for AGE key (e.g., sops/d2-admin/myserver)")
            BAO_KV_MOUNT=$(wizard ask "Enter KV engine mount" "secret")
        fi

        if wizard confirm "Configure OpenBao TLS client certificates?" no; then
            echo ""
            echo "Paste CA certificate PEM, then press Ctrl+D (leave blank if using a trusted CA like Let's Encrypt):"
            BAO_CACERT=$(cat | base64 -w0)
            echo ""
            echo "Paste client certificate PEM (may include chain), then press Ctrl+D:"
            BAO_CLIENT_CERT=$(cat | base64 -w0)
            echo ""
            echo "Paste client private key PEM, then press Ctrl+D:"
            BAO_CLIENT_KEY=$(cat | base64 -w0)
        fi

        if wizard confirm "Configure OpenBao namespace?" no; then
            BAO_NAMESPACE=$(wizard ask "Enter OpenBao namespace")
        fi
    fi

    ## Create SOPS config
    local PLAINTEXT="## SSH
SSH_HOST=${SSH_HOST}
SSH_USER=${SSH_USER}
SSH_PORT=${SSH_PORT}"
    if [[ -n "${KNOWN_HOSTS}" ]]; then
        local SSH_KNOWN_HOSTS
        SSH_KNOWN_HOSTS=$(echo "${KNOWN_HOSTS}" | base64 -w0)
        PLAINTEXT="${PLAINTEXT}
SSH_KNOWN_HOSTS=${SSH_KNOWN_HOSTS}"
    fi

    ## Append OpenBao vars if configured
    if [[ -n "${BAO_ADDR}" ]]; then
        PLAINTEXT="${PLAINTEXT}
## OpenBao
BAO_ADDR=${BAO_ADDR}
BAO_ROLE_ID=${BAO_ROLE_ID}
BAO_SECRET_ID=${BAO_SECRET_ID}
BAO_SSH_MOUNT=${BAO_SSH_MOUNT}
BAO_SSH_ROLE=${BAO_SSH_ROLE}
BAO_AUTH_PATH=${BAO_AUTH_PATH}"
        [[ -n "${BAO_AGE_KEY_PATH}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_AGE_KEY_PATH=${BAO_AGE_KEY_PATH}"
        [[ -n "${BAO_KV_MOUNT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_KV_MOUNT=${BAO_KV_MOUNT}"
        [[ -n "${BAO_NAMESPACE}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_NAMESPACE=${BAO_NAMESPACE}"
        [[ -n "${BAO_CACERT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CACERT=${BAO_CACERT}"
        [[ -n "${BAO_CLIENT_CERT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CLIENT_CERT=${BAO_CLIENT_CERT}"
        [[ -n "${BAO_CLIENT_KEY}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CLIENT_KEY=${BAO_CLIENT_KEY}"
    fi

    mkdir -p "${CONFIG_DIR}"
    echo "${PLAINTEXT}" | container_run -i \
        "${IMAGE}" \
        sh -c "cat > /tmp/plain.env && sops encrypt \
            --input-type dotenv --output-type dotenv \
            --filename-override export.env \
            --age '${PUBKEY}' /tmp/plain.env" \
        > "${CONFIG_DIR}/${CONTEXT}.sops.env"

    echo ""
    echo "Config saved to ${CONFIG_DIR}/${CONTEXT}.sops.env"
    echo ""
    echo "Init complete for context '${CONTEXT}'."
    echo ""
    echo "Next steps:"
    echo "  drt ${CONTEXT}"
}

###############################################################################
# run subcommand
###############################################################################

run_usage() {
    usage
}

cmd_run() {
    local AGE_KEY_FILE=""
    local SSH_KEY_FILE=""
    local SAVE_ON_EXIT=true
    local VERBOSE=false
    local SOPS_CONFIG=""
    local CMD_ARGS=()
    local CONTROLLER_PORT="${DRT_CONTROLLER_PORT:-8084}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --age-key) AGE_KEY_FILE="$2"; shift 2 ;;
            --ssh-key) SSH_KEY_FILE="$2"; shift 2 ;;
            --no-save) SAVE_ON_EXIT=false; shift ;;
            --ssh-timeout) SSH_CONNECT_TIMEOUT="$2"; export SSH_CONNECT_TIMEOUT; shift 2 ;;
            --timeout) TIMEOUT="$2"; export TIMEOUT; shift 2 ;;
            --verbose|-v) VERBOSE=true; shift ;;
            --controller-port) CONTROLLER_PORT="$2"; shift 2 ;;
            --help) run_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                run_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${SOPS_CONFIG}" ]]; then
                    SOPS_CONFIG="$1"
                    shift
                    # Everything after context is the command to run
                    CMD_ARGS=("$@")
                    break
                fi
                ;;
        esac
    done

    if [[ -z "${SOPS_CONFIG}" ]]; then
        echo "Error: CONTEXT_OR_FILE is required" >&2
        echo "" >&2
        run_usage >&2
        exit 1
    fi

    check_engine
    echo "## Resolving context: ${SOPS_CONFIG}" >&2

    # If argument is a bare context name (no slashes, no .sops.env suffix),
    # resolve to ~/.config/d.rymcg.tech/config/<context>.sops.env
    # and default the AGE key to the per-context key
    if [[ "${SOPS_CONFIG}" != */* && "${SOPS_CONFIG}" != *.sops.env ]]; then
        local CONTEXT_NAME="${SOPS_CONFIG}"
        SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT_NAME}.sops.env"
        if [[ -z "${AGE_KEY_FILE}" ]]; then
            AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT_NAME}.key"
        fi
    fi

    # Fall back to legacy default if no key resolved yet
    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"
    fi

    # Resolve to absolute path
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: SOPS config file not found: ${SOPS_CONFIG}" >&2
        echo "  Run 'drt --init' to create one." >&2
        exit 1
    fi
    SOPS_CONFIG="$(realpath "${SOPS_CONFIG}")"

    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key file not found: ${AGE_KEY_FILE}" >&2
        echo "  Use --age-key to specify a different path" >&2
        exit 1
    fi
    echo "## AGE key: ${AGE_KEY_FILE}" >&2
    echo "## SOPS config: ${SOPS_CONFIG}" >&2

    local CONTAINER_CONFIG_DIR=/home/user/git/vendor/enigmacurry/d.rymcg.tech/config
    local SOPS_BASENAME
    SOPS_BASENAME="$(basename "${SOPS_CONFIG}")"

    local RUN_ARGS=(
        run --rm -it --pull=never
        --security-opt label=disable
        --userns=keep-id
        -e "SOPS_CONFIG_FILE=${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${SOPS_CONFIG}:${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${AGE_KEY_FILE}:/home/user/.config/d.rymcg.tech/age-key:ro"
        -e "SOPS_AGE_KEY_FILE=/home/user/.config/d.rymcg.tech/age-key"
    )

    if [[ "${SAVE_ON_EXIT}" == true ]]; then
        RUN_ARGS+=(-e "SOPS_SAVE_ON_EXIT=true")
    fi

    if [[ "${VERBOSE}" == true ]]; then
        RUN_ARGS+=(-e "DRT_VERBOSE=true")
    fi

    # Forward host environment overrides into the container
    TIMEOUT="${TIMEOUT:-300}"; export TIMEOUT
    local passthrough_vars=(SSH_KEY_SCAN SSH_CONNECT_TIMEOUT TIMEOUT SSH_HOST SSH_USER SSH_PORT DOCKER_CONTEXT PROJECTS
        BAO_ADDR BAO_ROLE_ID BAO_SECRET_ID BAO_AGE_KEY_PATH BAO_SSH_MOUNT
        BAO_SSH_ROLE BAO_AUTH_PATH BAO_KV_MOUNT BAO_NAMESPACE
        BAO_CACERT BAO_CLIENT_CERT BAO_CLIENT_KEY BAO_SKIP)
    for var in "${passthrough_vars[@]}"; do
        if [[ -n "${!var:-}" ]]; then
            RUN_ARGS+=(-e "${var}=${!var}")
        fi
    done

    # SSH: forward agent or mount key file
    if [[ -n "${SSH_KEY_FILE}" ]]; then
        SSH_KEY_FILE="$(realpath "${SSH_KEY_FILE}")"
        if [[ ! -f "${SSH_KEY_FILE}" ]]; then
            echo "Error: SSH key file not found: ${SSH_KEY_FILE}" >&2
            exit 1
        fi
        echo "## SSH: mounting key file ${SSH_KEY_FILE}" >&2
        RUN_ARGS+=(-v "${SSH_KEY_FILE}:/run/secrets/ssh/id_ed25519:ro")
    elif [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        echo "## SSH: forwarding agent (${SSH_AUTH_SOCK})" >&2
        RUN_ARGS+=(
            -v "${SSH_AUTH_SOCK}:/run/ssh-agent.sock:ro"
            -e "SSH_AUTH_SOCK=/run/ssh-agent.sock"
        )
    else
        echo "## SSH: no key file or agent; container will generate a key" >&2
    fi

    # Persistent data volume (stores JWT master key, TLS certs)
    local CONTEXT_NAME="${SOPS_CONFIG}"
    if [[ "${CONTEXT_NAME}" == */* || "${CONTEXT_NAME}" == *.sops.env ]]; then
        CONTEXT_NAME="$(basename "${CONTEXT_NAME}" .sops.env)"
    fi
    RUN_ARGS+=(-v "drt-data-${CONTEXT_NAME}:/data")

    # Port mapping for request-controller
    local _is_controller=false
    for _arg in "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}"; do
        if [[ "${_arg}" == "request-controller" ]]; then
            _is_controller=true
            break
        fi
    done
    if [[ "${_is_controller}" == true ]]; then
        RUN_ARGS+=(-p "${CONTROLLER_PORT}:8084")
    fi

    RUN_ARGS+=("${IMAGE}")

    # Append command args (e.g. "drt d2 status" → "d.rymcg.tech status")
    if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
        RUN_ARGS+=("d.rymcg.tech" "${CMD_ARGS[@]}")
    fi

    echo "## Starting d-rymcg-tech container (${ENGINE})" >&2
    echo "## Config: ${SOPS_CONFIG}" >&2
    echo "## Image:  ${IMAGE}" >&2
    echo "## First run after a new image may take a moment (user namespace setup) ..." >&2
    if [[ "${VERBOSE}" == true ]]; then
        echo "## Full command: ${ENGINE} ${RUN_ARGS[*]}" >&2
    fi
    if [[ "${ENGINE}" == "docker" ]]; then
        exec "${ENGINE}" --context default "${RUN_ARGS[@]}"
    else
        exec "${ENGINE}" "${RUN_ARGS[@]}"
    fi
}

###############################################################################
# clean subcommand
###############################################################################

clean_usage() {
    cat <<'EOF'
Usage: drt --clean [OPTIONS] [CONTEXT_NAME]

Remove SOPS config and/or AGE key for a context.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_clean() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) clean_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                clean_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    clean_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine

    if [[ -z "${CONTEXT}" ]]; then
        local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${KEY_DIR}" ]]; then
            for f in "${KEY_DIR}"/*.key; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .key)")
            done
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                local name
                name="$(basename "$f" .sops.env)"
                local found=false
                for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                    if [[ "$c" == "$name" ]]; then found=true; break; fi
                done
                if [[ "$found" == false ]]; then
                    CONTEXTS+=("$name")
                fi
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "Nothing to clean — no contexts found."
            return
        fi
        CONTEXT=$(wizard choose "Select context to clean" "${CONTEXTS[@]}")
    fi

    local CONFIG_FILE="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    local AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    local DELETED=false

    ## Delete SOPS config
    if [[ -f "${CONFIG_FILE}" ]]; then
        if wizard confirm "Delete SOPS config ${CONFIG_FILE}?" no; then
            rm -f "${CONFIG_FILE}"
            echo "Deleted: ${CONFIG_FILE}"
            DELETED=true
        else
            echo "Kept: ${CONFIG_FILE}"
        fi
    else
        echo "No SOPS config found: ${CONFIG_FILE}"
    fi

    ## Delete AGE key
    if [[ -f "${AGE_KEY_FILE}" ]]; then
        if wizard confirm "Delete AGE key ${AGE_KEY_FILE}?" no; then
            rm -f "${AGE_KEY_FILE}"
            echo "Deleted: ${AGE_KEY_FILE}"
            DELETED=true
        else
            echo "Kept: ${AGE_KEY_FILE}"
        fi
    else
        echo "No AGE key found: ${AGE_KEY_FILE}"
    fi

    if [[ "${DELETED}" == true ]]; then
        echo ""
        echo "Clean complete for context '${CONTEXT}'."
    else
        echo ""
        echo "Nothing was deleted."
    fi
}

###############################################################################
# list subcommand
###############################################################################

cmd_list() {
    local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    local CONTEXTS=()

    ## Collect unique context names from keys and configs
    if [[ -d "${KEY_DIR}" ]]; then
        for f in "${KEY_DIR}"/*.key; do
            [[ -f "$f" ]] || continue
            CONTEXTS+=("$(basename "$f" .key)")
        done
    fi
    if [[ -d "${CONFIG_DIR}" ]]; then
        for f in "${CONFIG_DIR}"/*.sops.env; do
            [[ -f "$f" ]] || continue
            local name
            name="$(basename "$f" .sops.env)"
            ## Avoid duplicates
            local found=false
            for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                if [[ "$c" == "$name" ]]; then found=true; break; fi
            done
            if [[ "$found" == false ]]; then
                CONTEXTS+=("$name")
            fi
        done
    fi

    if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
        echo "No contexts found."
        return
    fi

    ## Sort contexts
    local SORTED
    SORTED=$(printf '%s\n' "${CONTEXTS[@]}" | sort)
    CONTEXTS=()
    while IFS= read -r ctx; do
        [[ -n "$ctx" ]] && CONTEXTS+=("$ctx")
    done <<< "$SORTED"

    printf "%-20s %-12s %s\n" "CONTEXT" "KEY" "CONFIG"
    printf "%-20s %-12s %s\n" "-------" "---" "------"
    for ctx in "${CONTEXTS[@]}"; do
        local key_status="missing"
        if [[ -f "${KEY_DIR}/${ctx}.key" ]]; then
            if head -1 "${KEY_DIR}/${ctx}.key" | grep -q '^age-encryption.org'; then
                key_status="encrypted"
            else
                key_status="plaintext!!"
            fi
        fi
        local config_status="missing"
        if [[ -f "${CONFIG_DIR}/${ctx}.sops.env" ]]; then
            config_status="${CONFIG_DIR}/${ctx}.sops.env"
        fi
        printf "%-20s %-12s %s\n" "$ctx" "$key_status" "$config_status"
    done
}

###############################################################################
# view subcommand
###############################################################################

view_usage() {
    cat <<'EOF'
Usage: drt --view [OPTIONS] [CONTEXT_NAME]

Decrypt and display a SOPS config file.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --age-key FILE AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --help         Show this help
EOF
}

cmd_view() {
    local CONTEXT="" AGE_KEY_FILE=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --age-key) AGE_KEY_FILE="$2"; shift 2 ;;
            --help) view_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                view_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    view_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine

    ## Pick context interactively if not provided
    if [[ -z "${CONTEXT}" ]]; then
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .sops.env)")
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "No configs found. Run 'drt --init' first." >&2
            exit 1
        fi
        CONTEXT=$(wizard choose "Select context to view" "${CONTEXTS[@]}")
    fi

    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    fi
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key not found: ${AGE_KEY_FILE}" >&2
        exit 1
    fi

    # Decrypt passphrase-protected AGE key in a separate interactive step
    local DEC_DIR=""
    if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
        DEC_DIR=$(mktemp -d)
        cp "${AGE_KEY_FILE}" "${DEC_DIR}/age-key-in"
        container_run -it --security-opt label=disable --userns=keep-id \
            -v "${DEC_DIR}:/tmp/age-work:Z" \
            "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-work/age-key-dec'
        AGE_KEY_FILE="${DEC_DIR}/age-key-dec"
    fi

    local PLAINTEXT
    PLAINTEXT=$(container_run \
        --security-opt label=disable --userns=keep-id -i \
        -v "${SOPS_CONFIG}:/tmp/config.sops.env:ro" \
        -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
        -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
        "${IMAGE}" \
        sops decrypt --input-type dotenv --output-type dotenv \
            --filename-override export.env /tmp/config.sops.env)

    [[ -n "${DEC_DIR}" ]] && rm -rf "${DEC_DIR}"

    if [[ -t 1 ]]; then
        echo "${PLAINTEXT}" | less
    else
        echo "${PLAINTEXT}"
    fi
}

###############################################################################
# extract subcommand
###############################################################################

cmd_extract() {
    if [[ -n "${DRT_IMAGE:-}" ]]; then
        sed "s|@@DRT_IMAGE@@|${DRT_IMAGE}|g" "$(readlink -f "$0")"
    else
        cat "$(readlink -f "$0")"
    fi
}

###############################################################################
# Main dispatch
###############################################################################

ACTION=run
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --init)
            ACTION=init
            shift
            ARGS+=("$@")
            break
            ;;
        --view)
            ACTION=view
            shift
            ARGS+=("$@")
            break
            ;;
        --clean)
            ACTION=clean
            shift
            ARGS+=("$@")
            break
            ;;
        --list)
            ACTION=list
            shift
            ;;
        --extract)
            ACTION=extract
            shift
            ;;
        --image)
            IMAGE="$2"
            ARGS+=(--image "$2")
            shift 2
            ;;
        --docker)
            ENGINE=docker
            ARGS+=(--docker)
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "drt ${VERSION}"
            exit 0
            ;;
        -*)
            # Pass through to cmd_run
            ARGS+=("$1")
            shift
            ;;
        *)
            # Positional arg = CONTEXT for run; collect rest too
            ARGS+=("$1")
            shift
            ARGS+=("$@")
            break
            ;;
    esac
done

case "${ACTION}" in
    init)
        cmd_init "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    view)
        cmd_view "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    clean)
        cmd_clean "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    list)
        cmd_list
        ;;
    extract)
        cmd_extract
        ;;
    run)
        if [[ ${#ARGS[@]} -eq 0 ]]; then
            check_engine
            echo "Run with --help to see full usage." >&2
            echo "" >&2
            _CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
            _KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
            _CHOICES=()
            if [[ -d "${_CONFIG_DIR}" ]]; then
                for f in "${_CONFIG_DIR}"/*.sops.env; do
                    [[ -f "$f" ]] || continue
                    _name="$(basename "$f" .sops.env)"
                    _key_status="no key"
                    if [[ -f "${_KEY_DIR}/${_name}.key" ]]; then
                        if head -1 "${_KEY_DIR}/${_name}.key" | grep -q '^age-encryption.org'; then
                            _key_status="encrypted key"
                        else
                            _key_status="plain-text key!!"
                        fi
                    fi
                    _CHOICES+=("${_name} (${_key_status}; ${f})")
                done
            fi
            if [[ ${#_CHOICES[@]} -eq 0 ]]; then
                echo "No configs found. Run 'drt --init' first." >&2
                exit 1
            fi
            _CHOICE=$(wizard choose "Select context to load" "${_CHOICES[@]}")
            ARGS+=("${_CHOICE%% *}")
        fi
        cmd_run "${ARGS[@]}"
        ;;
esac

###############################################################################
# How to setup the 'drt' alias for d.rymcg.tech:
# (Do this on your host workstation)
#
# Define a shell alias (add to ~/.bashrc or ~/.zshrc):
#
#   alias drt='bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt)'
#
# When you run e.g. "drt --init myserver", bash expands this to:
#
#   bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt) --init myserver
#
# The container entrypoint detects "drt" with no args and runs "drt --extract",
# which prints this script to stdout. The process substitution feeds it to
# bash, which executes it with the remaining arguments (--init myserver).
#
# The script itself never touches the container — it runs entirely on the
# host, orchestrating podman/docker to launch containers as needed.
#
# Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
###############################################################################
