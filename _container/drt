###############################################################################
# edit subcommand
###############################################################################

edit_usage() {
    cat <<'EOF'
Usage: drt --edit [OPTIONS] [CONTEXT_NAME]

Decrypt a SOPS config, edit it in $EDITOR, and re-encrypt.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --age-key FILE AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --help         Show this help
EOF
}

cmd_edit() {
    _parse_subcommand_args edit_usage "$@"
    local CONTEXT="${_SC_CONTEXT}"

    check_engine
    git_auto_pull

    _pick_context "Select context to edit" configs-only

    CONTEXT="${_SC_CONTEXT}"
    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    local AGE_KEY_FILE
    AGE_KEY_FILE=$(resolve_age_key "${CONTEXT}" "${_SC_AGE_KEY_FILE}")

    # Decrypt config
    local EDIT_DIR
    EDIT_DIR=$(mktemp -d)
    local EDIT_FILE="${EDIT_DIR}/${CONTEXT}.env"

    sops_decrypt_config "${AGE_KEY_FILE}" "${SOPS_CONFIG}" "${CONTEXT}" > "${EDIT_FILE}"
    chmod 600 "${EDIT_FILE}"

    # Save original for diffing
    local ORIG_FILE="${EDIT_DIR}/${CONTEXT}.env.orig"
    cp "${EDIT_FILE}" "${ORIG_FILE}"

    # Open editor
    "${EDITOR:-nano}" "${EDIT_FILE}"

    # Check if file was modified
    if diff -q "${ORIG_FILE}" "${EDIT_FILE}" &>/dev/null; then
        echo "## No changes made, config unchanged." >&2
        rm -rf "${EDIT_DIR}"
        exit 0
    fi

    # Show diff and confirm
    echo "" >&2
    echo "## Changes:" >&2
    diff -u "${ORIG_FILE}" "${EDIT_FILE}" >&2 || true
    echo "" >&2
    # Flush any stale input (e.g. escape sequences from editor)
    while read -r -t 0.1 _ 2>/dev/null; do :; done
    read -rp "Save changes to ${SOPS_CONFIG}? [Y/n] " answer
    if [[ "${answer}" =~ ^[Nn]$ ]]; then
        echo "## Changes discarded." >&2
        rm -rf "${EDIT_DIR}"
        exit 0
    fi

    # Re-encrypt using sops edit (only changed values re-encrypted)
    sops_reencrypt_config "${AGE_KEY_FILE}" "${SOPS_CONFIG}" "${EDIT_FILE}" "${CONTEXT}"

    echo "## Changes encrypted and saved to ${SOPS_CONFIG}" >&2

    rm -rf "${EDIT_DIR}"
    git_auto_commit "update context: ${CONTEXT}"
}

###############################################################################
# build subcommand
###############################################################################

DRT_GIT_REPO_DEFAULT="https://github.com/EnigmaCurry/d.rymcg.tech.git"

cmd_build() {
    local NO_CACHE=""
    if [[ "${1:-}" == "--no-cache" ]]; then
        NO_CACHE=1
        shift
    fi
    check_engine

    # Defaults from current image labels, overridable by env/args
    local REPO="${DRT_GIT_REPO:-}"
    if [[ -z "${REPO}" ]]; then
        REPO=$("${ENGINE}" image inspect "${IMAGE}" --format '{{index .Labels "drt.repo"}}' 2>/dev/null || true)
        REPO="${REPO:-${DRT_GIT_REPO_DEFAULT}}"
    fi

    # Priority: DRT_BUILD_BRANCH env > image label > master
    local BRANCH=""
    if [[ -n "${DRT_BUILD_BRANCH:-}" ]]; then
        BRANCH="${DRT_BUILD_BRANCH}"
    else
        BRANCH=$("${ENGINE}" image inspect "${IMAGE}" --format '{{index .Labels "drt.branch"}}' 2>/dev/null || true)
        BRANCH="${BRANCH:-master}"
    fi

    echo "## Building from ${REPO}#${BRANCH} ..." >&2
    _DRT_BUILD_DIR=$(mktemp -d)
    trap 'rm -rf "${_DRT_BUILD_DIR}"' EXIT
    git clone --depth 1 --branch "${BRANCH}" "${REPO}" "${_DRT_BUILD_DIR}/src"
    if [[ ! -f "${_DRT_BUILD_DIR}/src/_container/Dockerfile" ]]; then
        echo "Error: _container/Dockerfile not found on branch '${BRANCH}'." >&2
        echo "Set DRT_BUILD_BRANCH to a branch that has the Dockerfile." >&2
        exit 1
    fi
    local BUILD_ARGS=(build)
    # Podman: use slirp4netns if pasta fails during build
    if [[ "${ENGINE}" == "podman" ]]; then
        BUILD_ARGS+=(--network=slirp4netns)
    fi
    if [[ -n "${NO_CACHE}" ]]; then
        BUILD_ARGS+=(--no-cache)
    fi
    local GIT_SHA
    GIT_SHA=$(git -C "${_DRT_BUILD_DIR}/src" rev-parse --short HEAD 2>/dev/null || echo "unknown")
    BUILD_ARGS+=(
        --build-arg "BRANCH=${BRANCH}"
        --build-arg "GIT_REPO=${REPO}"
        --build-arg "GIT_SHA=${GIT_SHA}"
        --build-arg "INSTALL_EXTRAS=${DRT_INSTALL_EXTRAS:-}"
        -f "${_DRT_BUILD_DIR}/src/_container/Dockerfile"
        -t "${IMAGE}"
        "${_DRT_BUILD_DIR}/src"
    )
    "${ENGINE}" "${BUILD_ARGS[@]}"
    echo "## Built: ${IMAGE} (branch: ${BRANCH}, repo: ${REPO})" >&2
}

###############################################################################
# pull subcommand
###############################################################################

cmd_pull() {
    check_engine
    local LOCAL_ID=""
    if "${ENGINE}" image exists "${IMAGE}" 2>/dev/null; then
        LOCAL_ID=$("${ENGINE}" image inspect "${IMAGE}" --format '{{.Id}}' 2>/dev/null || true)
    fi
    "${ENGINE}" pull "${IMAGE}"
    local NEW_ID=""
    NEW_ID=$("${ENGINE}" image inspect "${IMAGE}" --format '{{.Id}}' 2>/dev/null || true)
    if [[ -n "${LOCAL_ID}" && "${LOCAL_ID}" == "${NEW_ID}" ]]; then
        echo "## Already up to date (${NEW_ID:0:19}...)" >&2
    elif [[ -n "${LOCAL_ID}" ]]; then
        echo "## Updated: ${LOCAL_ID:0:19}... → ${NEW_ID:0:19}..." >&2
    fi
}

###############################################################################
# shared: resolve BAO context → decrypt config, extract BAO_ADDR, build run args
###############################################################################

# Parse args and resolve context for seal/unseal commands.
# Uses _parse_subcommand_args and _pick_context helpers.
# Sets: _BAO_CONTEXT, _BAO_AGE_KEY_FILE (via _SC_ vars).
_bao_parse_args() {
    local help_action="$1"; shift
    _bao_usage() {
        echo "Usage: drt --${help_action} [OPTIONS] [CONTEXT_NAME]"
        echo ""
        echo "Options:"
        echo "  --image TAG    Container image"
        echo "  --age-key FILE AGE key file"
        echo "  --help         Show this help"
    }
    _parse_subcommand_args _bao_usage "$@"
    _BAO_CONTEXT="${_SC_CONTEXT}"
    _BAO_AGE_KEY_FILE="${_SC_AGE_KEY_FILE}"
}

# Resolve context, decrypt SOPS config, extract BAO vars, prepare container run args.
# Sets: _BAO_RUN_ARGS (array for engine run), _BAO_CTX (array for --context default).
_bao_resolve() {
    local wizard_prompt="$1"
    check_engine

    _SC_CONTEXT="${_BAO_CONTEXT}"
    _pick_context "${wizard_prompt}" configs-only
    _BAO_CONTEXT="${_SC_CONTEXT}"

    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${_BAO_CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    local AGE_KEY_FILE
    AGE_KEY_FILE=$(resolve_age_key "${_BAO_CONTEXT}" "${_BAO_AGE_KEY_FILE}")

    local PLAINTEXT
    PLAINTEXT=$(sops_decrypt_config "${AGE_KEY_FILE}" "${SOPS_CONFIG}" "${_BAO_CONTEXT}")

    local BAO_ADDR=""
    BAO_ADDR=$(echo "${PLAINTEXT}" | grep -oP '^BAO_ADDR=\K.*' || true)
    if [[ -z "${BAO_ADDR}" ]]; then
        echo "Error: BAO_ADDR not found in ${_BAO_CONTEXT} config — OpenBao is not configured for this context." >&2
        exit 1
    fi
    echo "## OpenBao server: ${BAO_ADDR}" >&2

    # Build env vars for the container
    local BAO_ENV=()
    local var
    local _has_cacert=false _has_client_cert=false
    for var in BAO_ADDR BAO_CACERT BAO_CLIENT_CERT BAO_CLIENT_KEY; do
        local val=""
        val=$(echo "${PLAINTEXT}" | grep -oP "^${var}=\\K.*" || true)
        if [[ -n "${val}" ]]; then
            BAO_ENV+=(-e "${var}=${val}")
            [[ "${var}" == "BAO_CACERT" ]] && _has_cacert=true
            [[ "${var}" == "BAO_CLIENT_CERT" ]] && _has_client_cert=true
        fi
    done
    if [[ "${_has_client_cert}" == "true" ]]; then
        echo "## TLS: mTLS (client certificate + CA)" >&2
    elif [[ "${_has_cacert}" == "true" ]]; then
        echo "## TLS: custom CA certificate" >&2
    fi

    detect_net_mode
    _BAO_RUN_ARGS=(run --rm -it --entrypoint "")
    [[ -n "${NET_MODE}" ]] && _BAO_RUN_ARGS+=(--net="${NET_MODE}")
    _BAO_RUN_ARGS+=("${BAO_ENV[@]}" "${IMAGE}")

    _BAO_CTX=()
}

# Inline TLS resolution script (sourced inside the container)
_BAO_TLS_SCRIPT='
TLS_FLAGS=()
_resolve_tls() {
    local var="$1" flag="$2" val="${!1:-}"
    [ -z "${val}" ] && return
    local f="/tmp/tls-${var}"
    if [ -f "${val}" ]; then
        f="${val}"
    elif echo "${val}" | grep -q "BEGIN"; then
        echo "${val}" > "${f}"
    elif [ ${#val} -gt 60 ] && echo "${val}" | grep -qE "^[A-Za-z0-9+/=]+$"; then
        echo "${val}" | base64 -d > "${f}"
    else
        echo "${val}" > "${f}"
    fi
    TLS_FLAGS+=("${flag}" "${f}")
}
_resolve_tls BAO_CACERT --cacert
_resolve_tls BAO_CLIENT_CERT --cert
_resolve_tls BAO_CLIENT_KEY --key
'

###############################################################################
# seal subcommand
###############################################################################

cmd_seal() {
    _bao_parse_args seal "$@"
    _bao_resolve "Select context to seal"

    "${ENGINE}" "${_BAO_CTX[@]}" "${_BAO_RUN_ARGS[@]}" bash -c '
set -eo pipefail
'"${_BAO_TLS_SCRIPT}"'

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
if [ -z "${STATUS}" ]; then
    echo "Error: could not reach ${BAO_ADDR}" >&2
    exit 1
fi

SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "true" ]; then
    echo "## OpenBao at ${BAO_ADDR} is already sealed." >&2
    exit 0
fi

printf "Seal the OpenBao server at %s? [y/N] " "${BAO_ADDR}" >&2
read -r answer < /dev/tty
case "${answer}" in
    [Yy]*) ;;
    *) echo "## Cancelled" >&2; exit 0 ;;
esac

printf "Root token: " >&2
read -rs ROOT_TOKEN < /dev/tty
echo "" >&2

curl -sf "${TLS_FLAGS[@]}" -X PUT \
    -H "X-Vault-Token: ${ROOT_TOKEN}" \
    "${BAO_ADDR}/v1/sys/seal" >/dev/null 2>&1 || true

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "true" ]; then
    echo "## OpenBao at ${BAO_ADDR} has been sealed." >&2
else
    echo "Error: seal failed. Check the root token and try again." >&2
    exit 1
fi'
}

###############################################################################
# unseal subcommand
###############################################################################

cmd_unseal() {
    _bao_parse_args unseal "$@"
    _bao_resolve "Select context to unseal"

    "${ENGINE}" "${_BAO_CTX[@]}" "${_BAO_RUN_ARGS[@]}" bash -c '
set -eo pipefail
'"${_BAO_TLS_SCRIPT}"'

STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
if [ -z "${STATUS}" ]; then
    echo "Error: could not reach ${BAO_ADDR}" >&2
    exit 1
fi

SEALED=$(echo "${STATUS}" | jq -r .sealed)
if [ "${SEALED}" = "false" ]; then
    echo "## OpenBao at ${BAO_ADDR} is already unsealed." >&2
    exit 0
fi

THRESHOLD=$(echo "${STATUS}" | jq -r .t)
TOTAL=$(echo "${STATUS}" | jq -r .n)
PROGRESS=$(echo "${STATUS}" | jq -r .progress)
echo "## Unseal requires ${THRESHOLD} of ${TOTAL} keys (${PROGRESS} already provided)" >&2

while true; do
    STATUS=$(curl -sf "${TLS_FLAGS[@]}" "${BAO_ADDR}/v1/sys/seal-status" 2>/dev/null || true)
    SEALED=$(echo "${STATUS}" | jq -r .sealed)
    PROGRESS=$(echo "${STATUS}" | jq -r .progress)

    if [ "${SEALED}" = "false" ]; then
        echo "## OpenBao at ${BAO_ADDR} has been unsealed." >&2
        exit 0
    fi

    printf "Unseal key (%s/%s): " "$((PROGRESS + 1))" "${THRESHOLD}" >&2
    read -rs UNSEAL_KEY < /dev/tty
    echo "" >&2

    RESPONSE=$(curl -sf "${TLS_FLAGS[@]}" -X PUT \
        --data "$(jq -n --arg k "${UNSEAL_KEY}" '{key:$k}')" \
        "${BAO_ADDR}/v1/sys/unseal" 2>/dev/null || true)

    if [ -z "${RESPONSE}" ]; then
        echo "Error: unseal request failed" >&2
        exit 1
    fi

    SEALED=$(echo "${RESPONSE}" | jq -r .sealed)
    PROGRESS=$(echo "${RESPONSE}" | jq -r .progress)

    if [ "${SEALED}" = "false" ]; then
        echo "## OpenBao at ${BAO_ADDR} has been unsealed." >&2
        exit 0
    fi

    echo "## Progress: ${PROGRESS}/${THRESHOLD}" >&2
done'
}

###############################################################################
# extract subcommand
###############################################################################

cmd_extract() {
    local script
    script="$(readlink -f "$0")"
    sed -e "s|@@DRT_IMAGE@@|${DRT_IMAGE:-localhost/d-rymcg-tech:latest}|g" \
        -e "s|@@DRT_GIT_SHA@@|${DRT_GIT_SHA:-unknown}|g" \
        "${script}"
}

###############################################################################
# Main dispatch
###############################################################################

ACTION=run
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --init)
            ACTION=init
            shift
            ARGS+=("$@")
            break
            ;;
        --view)
            ACTION=view
            shift
            ARGS+=("$@")
            break
            ;;
        --edit)
            ACTION=edit
            shift
            ARGS+=("$@")
            break
            ;;
        --clean)
            ACTION=clean
            shift
            ARGS+=("$@")
            break
            ;;
        --seal)
            ACTION=seal
            shift
            ARGS+=("$@")
            break
            ;;
        --unseal)
            ACTION=unseal
            shift
            ARGS+=("$@")
            break
            ;;
        --pull)
            ACTION=pull
            shift
            ;;
        --build)
            ACTION=build
            shift
            # Consume optional trailing args (e.g. context) — ignored for build
            while [[ $# -gt 0 ]]; do shift; done
            ;;
        --build-force)
            ACTION=build_force
            shift
            while [[ $# -gt 0 ]]; do shift; done
            ;;
        --list)
            ACTION=list
            shift
            ;;
        --git-init)
            ACTION=git_init
            shift
            ;;
        --git)
            ACTION=git
            shift
            ARGS=("$@")
            break
            ;;
        --extract)
            ACTION=extract
            shift
            ;;
        --image)
            IMAGE="$2"
            ARGS+=(--image "$2")
            shift 2
            ;;
        --net)
            NET_MODE="$2"
            ARGS+=(--net "$2")
            shift 2
            ;;
        --verbose|-v)
            ARGS+=(--verbose)
            shift
            ;;
        --cap-add)
            ARGS+=(--cap-add "$2")
            shift 2
            ;;
        --bind-mount)
            ARGS+=(--bind-mount "$2")
            shift 2
            ;;
        --cold-storage)
            ARGS+=(--cold-storage)
            shift
            ;;
        --wayland)
            ARGS+=(--wayland)
            shift
            ;;
        --pipewire)
            ARGS+=(--pipewire)
            shift
            ;;
        --no-git)
            DRT_NO_GIT=true
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "drt ${VERSION}"
            exit 0
            ;;
        -*)
            # Pass through to cmd_run
            ARGS+=("$1")
            shift
            ;;
        *)
            # Positional arg = CONTEXT for run; check remaining args for action flags
            ARGS+=("$1")
            shift
            # Scan remaining args: if an action flag appears, switch to that action
            for _remaining in "$@"; do
                case "${_remaining}" in
                    --init)   ACTION=init; break ;;
                    --view)   ACTION=view; break ;;
                    --edit)   ACTION=edit; break ;;
                    --clean)  ACTION=clean; break ;;
                    --seal)   ACTION=seal; break ;;
                    --unseal) ACTION=unseal; break ;;
                esac
            done
            if [[ "${ACTION}" != "run" ]]; then
                # Re-parse remaining args into ARGS (context already added)
                for _remaining in "$@"; do
                    [[ "${_remaining}" == "--${ACTION}" ]] && continue
                    ARGS+=("${_remaining}")
                done
            else
                ARGS+=("$@")
            fi
            break
            ;;
    esac
done

if [[ "${ACTION}" != "extract" ]]; then
    cat >&2 <<'WARN'

## WARNING: drt is experimental and is NOT a runtime security device!
## Only run this script on a secure, trusted device.
## Your secrets are ONLY encrypted AT REST!
## During runtime, all secrets are decrypted inside an ephemeral container
## filesystem, and any process in your user account (or root) can copy files
## in or out of the container via `podman cp`.

WARN
fi

case "${ACTION}" in
    init)
        cmd_init "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    view)
        cmd_view "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    edit)
        cmd_edit "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    clean)
        cmd_clean "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    seal)
        cmd_seal "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    unseal)
        cmd_unseal "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    pull)
        cmd_pull
        ;;
    build)
        cmd_build "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    build_force)
        cmd_build --no-cache "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    list)
        cmd_list
        ;;
    git_init)
        cmd_git_init
        ;;
    git)
        cmd_git "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    extract)
        cmd_extract
        ;;
    run)
        # Check if ARGS has a context (any non-flag argument, skipping flag values)
        _has_context=false
        _skip_next=false
        for _arg in "${ARGS[@]+"${ARGS[@]}"}"; do
            if [[ "${_skip_next}" == true ]]; then
                _skip_next=false
                continue
            fi
            case "${_arg}" in
                --cap-add|--image|--net|--age-key|--ssh-key|--ssh-timeout|--timeout|--controller-port|--bind-mount)
                    _skip_next=true ;;
                -*) ;;
                *) _has_context=true; break ;;
            esac
        done
        if [[ "${_has_context}" == false ]]; then
            check_engine
            echo "Run with --help to see full usage." >&2
            echo "" >&2
            _CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
            _KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
            _NAMES=()
            _STATUSES=()
            _PATHS=()
            _MAX_NAME_LEN=0
            if [[ -d "${_CONFIG_DIR}" ]]; then
                for f in "${_CONFIG_DIR}"/*.sops.env; do
                    [[ -f "$f" ]] || continue
                    _name="$(basename "$f" .sops.env)"
                    _key_status=$(key_status_label "${_KEY_DIR}/${_name}.key")
                    [[ "${_key_status}" == "missing" ]] && _key_status="no key"
                    _NAMES+=("${_name}")
                    _STATUSES+=("${_key_status}")
                    _PATHS+=("${f}")
                    (( ${#_name} > _MAX_NAME_LEN )) && _MAX_NAME_LEN=${#_name}
                done
            fi
            _CHOICES=()
            for i in "${!_NAMES[@]}"; do
                _CHOICES+=("$(printf "%-${_MAX_NAME_LEN}s  (%s; %s)" "${_NAMES[$i]}" "${_STATUSES[$i]}" "${_PATHS[$i]}")")
            done
            if [[ ${#_CHOICES[@]} -eq 0 ]]; then
                echo "No configs found. Run 'drt --init' first." >&2
                exit 1
            fi
            _CHOICE=$(wizard choose "Select context to decrypt" "${_CHOICES[@]}")
            ARGS+=("${_CHOICE%% *}")
        fi
        cmd_run "${ARGS[@]}"
        ;;
esac

###############################################################################
# How to setup the 'drt' alias for d.rymcg.tech:
# (Do this on your host workstation)
#
# Define a shell alias (add to ~/.bashrc or ~/.zshrc):
#
#   alias drt='bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt)'
#
# When you run e.g. "drt --init myserver", bash expands this to:
#
#   bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt) --init myserver
#
# The container entrypoint detects "drt" with no args and runs "drt --extract",
# which prints this script to stdout. The process substitution feeds it to
# bash, which executes it with the remaining arguments (--init myserver).
#
# The script itself never touches the container — it runs entirely on the
# host, orchestrating podman/docker to launch containers as needed.
#
# Host dependencies: bash, podman, openssh, coreutils, grep, gawk
###############################################################################
