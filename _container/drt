#!/usr/bin/env bash
## drt — d.rymcg.tech workstation bootstrap tool
## Combines init + run into a single script with no repo dependency.
## Host dependencies: bash, podman, openssh, coreutils, grep, gawk
## Setup alias:
##   alias drt='bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt)'
set -euo pipefail

VERSION="@@DRT_GIT_SHA@@"
if [[ "${VERSION}" == @@*@@ ]]; then
    VERSION="${DRT_GIT_SHA:-unknown}"
fi
DEFAULT_IMAGE="${DRT_IMAGE:-@@DRT_IMAGE@@}"
if [[ "${DEFAULT_IMAGE}" == @@*@@ ]]; then
    DEFAULT_IMAGE="localhost/d-rymcg-tech:latest"
fi

###############################################################################
# Shared helpers
###############################################################################

ENGINE=podman
IMAGE="${DEFAULT_IMAGE}"
BUILD=false
NET_MODE=""

check_engine() {
    if ! command -v "${ENGINE}" &>/dev/null; then
        echo "Error: ${ENGINE} not found in PATH" >&2
        exit 1
    fi
}

## Detect working network mode for podman (pasta may be broken on some systems)
## Caches result in ~/.config/d.rymcg.tech/net-mode
detect_net_mode() {
    [[ -n "${NET_MODE}" ]] && return
    [[ "${ENGINE}" != "podman" ]] && return
    local CACHE_FILE="${HOME}/.config/d.rymcg.tech/net-mode"
    if [[ -f "${CACHE_FILE}" ]]; then
        NET_MODE=$(cat "${CACHE_FILE}")
        return
    fi
    echo "## Detecting network mode (one-time check) ..." >&2
    if "${ENGINE}" run --rm --net=pasta --entrypoint "" "${IMAGE}" true 2>/dev/null; then
        NET_MODE=pasta
    elif "${ENGINE}" run --rm --net=slirp4netns --entrypoint "" "${IMAGE}" true 2>/dev/null; then
        NET_MODE=slirp4netns
        echo "## Network: using slirp4netns (pasta unavailable)" >&2
    else
        NET_MODE=host
        echo "## Network: using host (pasta and slirp4netns unavailable)" >&2
    fi
    mkdir -p "$(dirname "${CACHE_FILE}")" 2>/dev/null
    echo "${NET_MODE}" > "${CACHE_FILE}" 2>/dev/null || true
}

## Run a command inside the container, bypassing the entrypoint
container_run() {
    "${ENGINE}" run --rm --net=none --entrypoint "" "$@"
}

## Run script-wizard inside the container interactively
## Uses a named container so we can copy the answer out after it exits
wizard() {
    local cname="wizard-$$-${RANDOM}"
    local answer="/tmp/wizard-answer-${cname}"
    trap '"${ENGINE}" rm "${cname}" >/dev/null 2>&1' EXIT
    "${ENGINE}" run -it --net=none --name "${cname}" --entrypoint "" \
        -e "TERM=${TERM:-xterm}" -e "WIZARD_ANSWER=${answer}" \
        "${IMAGE}" \
        sh -c 'script-wizard "$@" > "${WIZARD_ANSWER}"' -- "$@" >&2
    local rc=$?
    "${ENGINE}" cp "${cname}:${answer}" - | tar -xO
    trap - EXIT
    "${ENGINE}" "${_ctx[@]}" rm "${cname}" >/dev/null
    return $rc
}

## List FIDO2 hidraw devices with human-readable names
## Filters by checking for FIDO usage page (0xF1D0) in the HID report descriptor
## Output: one line per device: "/dev/hidrawN|HID_ID|Device Name"
detect_hidraw_devices() {
    for dev in /dev/hidraw*; do
        [[ -e "$dev" ]] || continue
        local sysdev="/sys/class/hidraw/$(basename "$dev")/device"
        # Check for FIDO usage page (0xF1D0) in report descriptor
        local report_desc="${sysdev}/report_descriptor"
        if [[ -f "${report_desc}" ]]; then
            # FIDO usage page appears as bytes 06 D0 F1 in the HID descriptor
            if ! od -An -tx1 "${report_desc}" 2>/dev/null | tr -d ' \n' | grep -qi '06d0f1'; then
                continue
            fi
        else
            continue
        fi
        local name="" hidid=""
        if [[ -f "${sysdev}/uevent" ]]; then
            name=$(grep '^HID_NAME=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
            hidid=$(grep '^HID_ID=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
        fi
        [[ -z "$name" ]] && name="Unknown"
        echo "${dev}|${hidid}|${name}"
    done
}

## Find hidraw device path by stored HID_ID
## Args: $1 = HID_ID string (e.g. "0003:00001209:00005070")
## Output: /dev/hidrawN path
find_hidraw_by_id() {
    local target_id="$1"
    for dev in /dev/hidraw*; do
        [[ -e "$dev" ]] || continue
        local sysdev="/sys/class/hidraw/$(basename "$dev")/device"
        if [[ -f "${sysdev}/uevent" ]]; then
            local hidid
            hidid=$(grep '^HID_ID=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
            if [[ "$hidid" == "$target_id" ]]; then
                echo "$dev"
                return 0
            fi
        fi
    done
    return 1
}

## Pull from remote if ~/.config/d.rymcg.tech is a git repo with a remote
git_auto_pull() {
    [[ "${DRT_NO_GIT:-}" == true ]] && return 0
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    [[ -d "${CONFIG_BASE}/.git" ]] || return 0
    local remote
    remote=$(git -C "${CONFIG_BASE}" remote 2>/dev/null | head -1)
    [[ -n "${remote}" ]] || return 0
    if [[ -t 0 ]]; then
        read -rp "## git: pull from ${remote}? [Y/n] " _pull_answer
        if [[ "${_pull_answer}" =~ ^[Nn]$ ]]; then
            echo "## git: pull skipped" >&2
            return 0
        fi
    fi
    echo "## git: fetching from ${remote} ..." >&2
    if ! git -C "${CONFIG_BASE}" fetch "${remote}" 2>&1; then
        echo "" >&2
        echo "ERROR: git fetch failed. Check your network connection and ssh-agent." >&2
        echo "  Use --no-git to skip." >&2
        exit 1
    fi
    local branch
    branch=$(git -C "${CONFIG_BASE}" branch --show-current 2>/dev/null)
    [[ -n "${branch}" ]] || return 0
    if git -C "${CONFIG_BASE}" rev-parse "${remote}/${branch}" &>/dev/null; then
        if ! git -C "${CONFIG_BASE}" merge --ff-only "${remote}/${branch}" 2>/dev/null; then
            echo "ERROR: config repo has diverged from ${remote}/${branch} — resolve manually with: drt --git" >&2
            exit 1
        fi
        echo "## git: up to date with ${remote}/${branch}" >&2
    fi
}

## Ensure base directory structure for config
ensure_config_dir() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    mkdir -p "${CONFIG_BASE}/keys/sops" "${CONFIG_BASE}/config"
    if [[ ! -f "${CONFIG_BASE}/.gitignore" ]]; then
        cat > "${CONFIG_BASE}/.gitignore" <<'GITIGNORE'
net-mode
keys/*
gumdrop-presets/*
GITIGNORE
    else
        # Ensure newer ignore entries are present in existing .gitignore
        grep -qx 'gumdrop-presets/\*' "${CONFIG_BASE}/.gitignore" 2>/dev/null || \
            echo 'gumdrop-presets/*' >> "${CONFIG_BASE}/.gitignore"
    fi
    if [[ ! -f "${CONFIG_BASE}/keys/.gitkeep" ]]; then
        touch "${CONFIG_BASE}/keys/.gitkeep"
    fi
}

## Auto-commit config changes if ~/.config/d.rymcg.tech is a git repo
git_auto_commit() {
    [[ "${DRT_NO_GIT:-}" == true ]] && return 0
    local msg="$1"
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    [[ -d "${CONFIG_BASE}/.git" ]] || return 0
    echo "## git: staging changes ..." >&2
    git -C "${CONFIG_BASE}" add -A
    if git -C "${CONFIG_BASE}" diff --cached --quiet; then
        echo "## git: no changes to commit" >&2
        return 0
    fi
    if ! git -C "${CONFIG_BASE}" commit -m "${msg}" >/dev/null 2>&1; then
        echo "## git: commit failed — you may need to configure git identity:" >&2
        echo "##   drt --git config user.email \"you@example.com\"" >&2
        echo "##   drt --git config user.name \"Your Name\"" >&2
        return 1
    fi
    echo "## git: committed: ${msg}" >&2
    local remote
    remote=$(git -C "${CONFIG_BASE}" remote 2>/dev/null | head -1)
    if [[ -n "${remote}" ]]; then
        read -rp "## git: push to ${remote}? [Y/n] " answer </dev/tty
        if [[ ! "${answer}" =~ ^[Nn]$ ]]; then
            git -C "${CONFIG_BASE}" push 2>/dev/null && \
                echo "## git: pushed" >&2 || \
                echo "## git: push failed" >&2
        fi
    fi
}

## Detect AGE key type: passphrase, fido2, or plaintext
## Args: $1 = path to AGE key file
## Output: "passphrase", "fido2", or "plaintext"
detect_key_type() {
    local key_file="$1"
    if head -1 "${key_file}" | grep -q '^age-encryption.org'; then
        echo "passphrase"
    elif grep -q 'AGE-PLUGIN-FIDO2-HMAC' "${key_file}" 2>/dev/null; then
        echo "fido2"
    else
        echo "plaintext"
    fi
}

## Human-readable key status label
## Args: $1 = path to AGE key file (may not exist)
## Output: status string
key_status_label() {
    local key_file="$1"
    if [[ ! -f "${key_file}" ]]; then
        echo "missing"
        return
    fi
    case "$(detect_key_type "${key_file}")" in
        passphrase) echo "Password" ;;
        fido2) echo "FIDO2 + Cold Storage" ;;
        plaintext) echo "plaintext!!" ;;
    esac
}

## List unique context names from keys and/or configs
## Args: $1 = "configs-only" to list only configs (optional)
## Output: sorted unique context names, one per line
list_contexts() {
    local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    {
        if [[ "${1:-}" != "configs-only" && -d "${KEY_DIR}" ]]; then
            for f in "${KEY_DIR}"/*.key; do
                [[ -f "$f" ]] || continue
                basename "$f" .key
            done
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                basename "$f" .sops.env
            done
        fi
    } | sort -u
}

## Resolve AGE key file path for a context, validate existence
## Args: $1 = context name, $2 = optional override path
## Output: path to key file; exits with error if not found
resolve_age_key() {
    local context="$1" override="${2:-}"
    local key_file
    if [[ -n "${override}" ]]; then
        key_file="${override}"
    else
        key_file="${HOME}/.config/d.rymcg.tech/keys/sops/${context}.key"
    fi
    if [[ ! -f "${key_file}" ]]; then
        echo "Error: AGE key not found: ${key_file}" >&2
        exit 1
    fi
    echo "${key_file}"
}

## Resolve FIDO2 device for a context
## Args: $1 = context name, $2 = "interactive" for fallback selection (optional)
## Output: /dev/hidrawN path; returns 1 if not found (non-interactive) or exits on error
resolve_fido2_device() {
    local context="$1" mode="${2:-}"
    local FIDO2_ID_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${context}.fido2"
    local fido2_dev=""

    if [[ -f "${FIDO2_ID_FILE}" ]]; then
        local _fido2_id
        while IFS= read -r _fido2_id; do
            [[ -z "${_fido2_id}" ]] && continue
            fido2_dev=$(find_hidraw_by_id "${_fido2_id}") && break
        done < "${FIDO2_ID_FILE}"
    fi

    if [[ -n "${fido2_dev}" ]]; then
        echo "${fido2_dev}"
        return 0
    fi

    if [[ "${mode}" == "interactive" ]]; then
        echo "## FIDO2: no stored device found, scanning..." >&2
        local _devs=() _devpaths=()
        while IFS='|' read -r devpath hidid devname; do
            _devs+=("${devname} (${devpath})")
            _devpaths+=("${devpath}")
        done < <(detect_hidraw_devices)
        if [[ ${#_devs[@]} -eq 0 ]]; then
            echo "Error: no FIDO2 devices detected" >&2
            echo "  Ensure one of your FIDO2 keys is plugged in" >&2
            exit 1
        fi
        local _sel _sel_idx=0
        _sel=$(wizard choose "Select FIDO2 device" "${_devs[@]}")
        for i in "${!_devs[@]}"; do
            [[ "${_devs[$i]}" == "${_sel}" ]] && _sel_idx=$i && break
        done
        echo "${_devpaths[$_sel_idx]}"
        return 0
    fi

    return 1
}

## Decrypt a SOPS config file, handling all key types
## Args: $1 = AGE key file, $2 = SOPS config file, $3 = context name
## Output: decrypted plaintext to stdout
sops_decrypt_config() {
    local key_file="$1" config_file="$2" context="$3"
    local key_type
    key_type=$(detect_key_type "${key_file}")

    local _dec_dir
    _dec_dir=$(mktemp -d)
    cp "${key_file}" "${_dec_dir}/age-key-in"
    cp "${config_file}" "${_dec_dir}/config.sops.env"

    local _extra_args=()
    case "${key_type}" in
        passphrase)
            _extra_args+=(-it)
            echo "## Get ready to enter your AGE key passphrase ..." >&2
            ;;
        fido2)
            local _fido2_dev=""
            _fido2_dev=$(resolve_fido2_device "${context}") || true
            if [[ -z "${_fido2_dev}" ]]; then
                rm -rf "${_dec_dir}"
                echo "Error: FIDO2 device not found. Ensure your key is plugged in." >&2
                exit 1
            fi
            _extra_args+=(-it --device "${_fido2_dev}")
            echo "## Touch your FIDO2 key when it flashes ..." >&2
            ;;
    esac

    container_run ${_extra_args[@]+"${_extra_args[@]}"} \
        --user 0:0 --security-opt label=disable \
        -v "${_dec_dir}:/tmp/dec-work:Z" \
        "${IMAGE}" sh -c '
            if head -1 /tmp/dec-work/age-key-in | grep -q "^age-encryption.org"; then
                age -d /tmp/dec-work/age-key-in > /tmp/age-key-dec
            else
                cp /tmp/dec-work/age-key-in /tmp/age-key-dec
            fi
            SOPS_AGE_KEY_FILE=/tmp/age-key-dec sops decrypt \
                --input-type dotenv --output-type dotenv \
                --filename-override export.env /tmp/dec-work/config.sops.env \
                > /tmp/dec-work/config-decrypted && \
                chmod 644 /tmp/dec-work/config-decrypted'

    if [[ "${key_type}" == "passphrase" ]]; then
        echo "## Passphrase accepted." >&2
    fi

    cat "${_dec_dir}/config-decrypted"
    rm -rf "${_dec_dir}"
}

## Re-encrypt a SOPS config using the EDITOR=cp trick (only changed values re-encrypted)
## Args: $1 = AGE key file, $2 = SOPS config file (updated in place), $3 = new plaintext file, $4 = context name
sops_reencrypt_config() {
    local key_file="$1" config_file="$2" plaintext_file="$3" context="$4"
    local key_type
    key_type=$(detect_key_type "${key_file}")

    local _enc_dir
    _enc_dir=$(mktemp -d)
    cp "${plaintext_file}" "${_enc_dir}/new-plain.env"
    cp "${key_file}" "${_enc_dir}/age-key-in"
    cp "${config_file}" "${_enc_dir}/config.sops.env"

    local _extra_args=()
    case "${key_type}" in
        passphrase)
            echo "## Get ready to enter your AGE key passphrase ..." >&2
            ;;
        fido2)
            local _fido2_dev=""
            _fido2_dev=$(resolve_fido2_device "${context}") || true
            if [[ -n "${_fido2_dev}" ]]; then
                _extra_args+=(--device "${_fido2_dev}")
                echo "## Touch your FIDO2 key when it flashes ..." >&2
            fi
            ;;
    esac

    container_run -it --user 0:0 \
        --security-opt label=disable \
        ${_extra_args[@]+"${_extra_args[@]}"} \
        -v "${_enc_dir}:/tmp/enc-work:Z" \
        "${IMAGE}" sh -c '
            if head -1 /tmp/enc-work/age-key-in | grep -q "^age-encryption.org"; then
                age -d /tmp/enc-work/age-key-in > /tmp/age-key-dec
            else
                cp /tmp/enc-work/age-key-in /tmp/age-key-dec
            fi
            export SOPS_AGE_KEY_FILE=/tmp/age-key-dec
            EDITOR="cp /tmp/enc-work/new-plain.env" sops \
                --input-type dotenv --output-type dotenv \
                /tmp/enc-work/config.sops.env
            chmod 644 /tmp/enc-work/config.sops.env'

    cp "${_enc_dir}/config.sops.env" "${config_file}"
    rm -rf "${_enc_dir}"
}

## Parse common subcommand args: --image, --age-key, --help, positional CONTEXT
## Args: $1 = usage function name, remaining = subcommand args
## Sets: _SC_CONTEXT, _SC_AGE_KEY_FILE
_parse_subcommand_args() {
    local _usage_fn="$1"; shift
    _SC_CONTEXT=""
    _SC_AGE_KEY_FILE=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --age-key) _SC_AGE_KEY_FILE="$2"; shift 2 ;;
            --help) "${_usage_fn}"; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                "${_usage_fn}" >&2
                exit 1
                ;;
            *)
                if [[ -z "${_SC_CONTEXT}" ]]; then
                    _SC_CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    "${_usage_fn}" >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done
}

## Interactively pick a context if _SC_CONTEXT is empty
## Args: $1 = wizard prompt, $2 = list mode ("configs-only" or empty for all)
_pick_context() {
    [[ -n "${_SC_CONTEXT}" ]] && return
    local _contexts=()
    while IFS= read -r _ctx; do
        [[ -n "${_ctx}" ]] && _contexts+=("${_ctx}")
    done < <(list_contexts "${2:-}")
    if [[ ${#_contexts[@]} -eq 0 ]]; then
        echo "No configs found. Run 'drt --init' first." >&2
        exit 1
    fi
    _SC_CONTEXT=$(wizard choose "$1" "${_contexts[@]}")
}

