#!/usr/bin/env bash
## drt — standalone d-rymcg-tech bootstrap tool
## Combines init + run into a single script with no repo dependency.
## Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
## Setup alias:
##   alias drt='bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt)'
set -euo pipefail

VERSION="1.0.0"
DEFAULT_IMAGE="@@DRT_IMAGE@@"

###############################################################################
# Shared helpers
###############################################################################

ENGINE=podman
IMAGE="${DEFAULT_IMAGE}"
BUILD=false

check_engine() {
    if ! command -v "${ENGINE}" &>/dev/null; then
        echo "Error: ${ENGINE} not found in PATH" >&2
        echo "Install ${ENGINE} first, or use --docker to use Docker instead." >&2
        exit 1
    fi
}

## Run a command inside the container, bypassing the entrypoint
container_run() {
    "${ENGINE}" run --rm --entrypoint "" "$@"
}

## Run script-wizard inside the container interactively
## Uses a named container so we can copy the answer out after it exits
wizard() {
    local cname="wizard-$$-${RANDOM}"
    local answer="/tmp/wizard-answer-${cname}"
    trap '"${ENGINE}" rm "${cname}" >/dev/null 2>&1' EXIT
    "${ENGINE}" run -it --name "${cname}" --entrypoint "" \
        -e "TERM=${TERM:-xterm}" -e "WIZARD_ANSWER=${answer}" \
        "${IMAGE}" \
        sh -c 'script-wizard "$@" > "${WIZARD_ANSWER}"' -- "$@" >&2
    local rc=$?
    "${ENGINE}" cp "${cname}:${answer}" - | tar -xO
    trap - EXIT
    "${ENGINE}" rm "${cname}" >/dev/null
    return $rc
}

###############################################################################
# Top-level usage
###############################################################################

usage() {
    cat <<'EOF'
drt — standalone d-rymcg-tech bootstrap tool

Usage:
  drt [OPTIONS] CONTEXT [CMD]  Launch container (interactive shell or run CMD)

Options:
  --init [CONTEXT]   Bootstrap AGE key + SOPS config for a context
  --clean [CONTEXT]  Remove SOPS config and/or AGE key for a context
  --list             List all contexts (AGE keys and SOPS configs)
  --extract          Print this script to stdout (self-extraction)
  --image TAG        Container image (default: localhost/d-rymcg-tech:latest)
  --docker           Use Docker instead of Podman
  --age-key FILE     AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --ssh-key FILE     SSH key file (disables agent forwarding)
  --no-save          Disable save-on-exit
  --version          Print version
  --help             Show this help
EOF
    echo ""
    echo "One time setup:"
    if [[ "${IMAGE}" != localhost/* ]]; then
        echo "  ${ENGINE} pull ${IMAGE}"
    fi
    echo "  alias drt='bash <(${ENGINE} run --rm --pull=never ${IMAGE} drt)'"
}

###############################################################################
# init subcommand
###############################################################################

init_usage() {
    cat <<'EOF'
Usage: drt --init [OPTIONS] [CONTEXT_NAME]

Bootstrap a new d-rymcg-tech deployment config.

Generates an AGE encryption key (if needed) and creates a SOPS-encrypted
config file for the given context. Only requires Podman (or Docker).

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_init() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) init_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                init_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    init_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine

    ## Context name
    if [[ -z "${CONTEXT}" ]]; then
        CONTEXT=$(wizard ask "Enter the context name (SSH host alias)")
    fi

    ## Check for existing config
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
        echo "Config already exists: ${CONFIG_DIR}/${CONTEXT}.sops.env"
        echo ""
        echo "To modify it interactively, run:"
        echo "  drt ${CONTEXT}"
        exit 0
    fi

    ## Ensure AGE key (one per context)
    local AGE_KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local AGE_KEY_FILE="${AGE_KEY_DIR}/${CONTEXT}.key"
    local PUBKEY
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "No AGE key found for context '${CONTEXT}'"
        echo "Generating a new AGE keypair..."
        mkdir -p "${AGE_KEY_DIR}"
        container_run "${IMAGE}" age-keygen > "${AGE_KEY_FILE}"
        chmod 600 "${AGE_KEY_FILE}"

        ## Extract public key while file is still plaintext
        PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)

        ## Optional passphrase protection
        if wizard confirm "Password-protect the AGE key?" no; then
            local PLAIN_KEY="${AGE_KEY_FILE}.plain"
            mv "${AGE_KEY_FILE}" "${PLAIN_KEY}"
            container_run -it "${IMAGE}" age -p < "${PLAIN_KEY}" > "${AGE_KEY_FILE}"
            rm -f "${PLAIN_KEY}"
            chmod 600 "${AGE_KEY_FILE}"
            echo "AGE key created (passphrase-protected): ${AGE_KEY_FILE}"
        else
            echo "AGE key created: ${AGE_KEY_FILE}"
        fi
    else
        echo "Using existing AGE key: ${AGE_KEY_FILE}"
        ## Extract public key — if encrypted, need to decrypt first
        if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
            PUBKEY=$(container_run -it "${IMAGE}" age -d < "${AGE_KEY_FILE}" | grep -o 'age1[a-z0-9]*' | head -1)
        else
            PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)
            echo "WARNING: AGE key is NOT password-protected."
        fi
    fi
    echo "AGE public key: ${PUBKEY}"
    echo ""

    ## SSH details — pre-fill from ssh config if available
    local SSH_CONFIG SSH_HOST SSH_PORT SSH_USER
    SSH_CONFIG=$(ssh -G "${CONTEXT}" 2>/dev/null || true)
    local _SSH_HOST _SSH_PORT _SSH_USER
    _SSH_HOST=$(echo "${SSH_CONFIG}" | awk '/^hostname / {print $2}')
    _SSH_PORT=$(echo "${SSH_CONFIG}" | awk '/^port / {print $2; exit}')
    _SSH_USER=$(echo "${SSH_CONFIG}" | awk '/^user / {print $2}')

    SSH_HOST=$(wizard ask "Enter SSH host" "${_SSH_HOST}")
    SSH_PORT=$(wizard ask "Enter SSH port" "${_SSH_PORT:-22}")
    SSH_USER=$(wizard ask "Enter SSH user" "${_SSH_USER:-root}")

    ## SSH key scan
    echo ""
    echo "Running ssh-keyscan for ${SSH_HOST}:${SSH_PORT}..."
    local KNOWN_HOSTS
    KNOWN_HOSTS=$(ssh-keyscan -p "${SSH_PORT}" "${SSH_HOST}" 2>/dev/null || true)
    if [[ -z "${KNOWN_HOSTS}" ]]; then
        echo "WARNING: ssh-keyscan failed for ${SSH_HOST}:${SSH_PORT}"
        echo "  You can set SSH_KNOWN_HOSTS later, or set SSH_KEY_SCAN=false to skip verification."
    else
        echo "SSH host keys collected."
    fi

    ## Create SOPS config
    local PLAINTEXT="## SSH
SSH_HOST=${SSH_HOST}
SSH_USER=${SSH_USER}
SSH_PORT=${SSH_PORT}"
    if [[ -n "${KNOWN_HOSTS}" ]]; then
        local SSH_KNOWN_HOSTS
        SSH_KNOWN_HOSTS=$(echo "${KNOWN_HOSTS}" | base64 -w0)
        PLAINTEXT="${PLAINTEXT}
SSH_KNOWN_HOSTS=${SSH_KNOWN_HOSTS}"
    fi

    mkdir -p "${CONFIG_DIR}"
    echo "${PLAINTEXT}" | container_run -i \
        "${IMAGE}" \
        sh -c "cat > /tmp/plain.env && sops encrypt \
            --input-type dotenv --output-type dotenv \
            --filename-override export.env \
            --age '${PUBKEY}' /tmp/plain.env" \
        > "${CONFIG_DIR}/${CONTEXT}.sops.env"

    echo ""
    echo "Config saved to ${CONFIG_DIR}/${CONTEXT}.sops.env"
    echo ""
    echo "Init complete for context '${CONTEXT}'."
    echo ""
    echo "Next steps:"
    echo "  drt ${CONTEXT}"
}

###############################################################################
# run subcommand
###############################################################################

run_usage() {
    usage
}

cmd_run() {
    local AGE_KEY_FILE=""
    local SSH_KEY_FILE=""
    local SAVE_ON_EXIT=true
    local SOPS_CONFIG=""
    local CMD_ARGS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --age-key) AGE_KEY_FILE="$2"; shift 2 ;;
            --ssh-key) SSH_KEY_FILE="$2"; shift 2 ;;
            --no-save) SAVE_ON_EXIT=false; shift ;;
            --help) run_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                run_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${SOPS_CONFIG}" ]]; then
                    SOPS_CONFIG="$1"
                    shift
                    # Everything after context is the command to run
                    CMD_ARGS=("$@")
                    break
                fi
                ;;
        esac
    done

    if [[ -z "${SOPS_CONFIG}" ]]; then
        echo "Error: CONTEXT_OR_FILE is required" >&2
        echo "" >&2
        run_usage >&2
        exit 1
    fi

    check_engine

    # If argument is a bare context name (no slashes, no .sops.env suffix),
    # resolve to ~/.config/d.rymcg.tech/config/<context>.sops.env
    # and default the AGE key to the per-context key
    if [[ "${SOPS_CONFIG}" != */* && "${SOPS_CONFIG}" != *.sops.env ]]; then
        local CONTEXT_NAME="${SOPS_CONFIG}"
        SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT_NAME}.sops.env"
        if [[ -z "${AGE_KEY_FILE}" ]]; then
            AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT_NAME}.key"
        fi
    fi

    # Fall back to legacy default if no key resolved yet
    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"
    fi

    # Resolve to absolute path
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: SOPS config file not found: ${SOPS_CONFIG}" >&2
        echo "  Run 'drt --init' to create one." >&2
        exit 1
    fi
    SOPS_CONFIG="$(realpath "${SOPS_CONFIG}")"

    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key file not found: ${AGE_KEY_FILE}" >&2
        echo "  Use --age-key to specify a different path" >&2
        exit 1
    fi

    ## Decrypt passphrase-protected AGE key to a temp file
    if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
        echo "## AGE key is passphrase-protected, decrypting..." >&2
        local DECRYPTED_KEY
        DECRYPTED_KEY=$(mktemp)
        if ! container_run -it "${IMAGE}" age -d < "${AGE_KEY_FILE}" > "${DECRYPTED_KEY}"; then
            rm -f "${DECRYPTED_KEY}"
            echo "Error: failed to decrypt AGE key" >&2
            exit 1
        fi
        chmod 600 "${DECRYPTED_KEY}"
        AGE_KEY_FILE="${DECRYPTED_KEY}"
        trap "rm -f '${DECRYPTED_KEY}'" EXIT
    fi

    local CONTAINER_CONFIG_DIR=/home/user/git/vendor/enigmacurry/d.rymcg.tech/config
    local SOPS_BASENAME
    SOPS_BASENAME="$(basename "${SOPS_CONFIG}")"

    local RUN_ARGS=(
        run --rm -it
        --security-opt label=disable
        --userns=keep-id
        -e "SOPS_CONFIG_FILE=${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${SOPS_CONFIG}:${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${AGE_KEY_FILE}:/home/user/.config/sops/age/keys.txt:ro"
        -e "SOPS_AGE_KEY_FILE=/home/user/.config/sops/age/keys.txt"
    )

    if [[ "${SAVE_ON_EXIT}" == true ]]; then
        RUN_ARGS+=(-e "SOPS_SAVE_ON_EXIT=true")
    fi

    # SSH: forward agent or mount key file
    if [[ -n "${SSH_KEY_FILE}" ]]; then
        SSH_KEY_FILE="$(realpath "${SSH_KEY_FILE}")"
        if [[ ! -f "${SSH_KEY_FILE}" ]]; then
            echo "Error: SSH key file not found: ${SSH_KEY_FILE}" >&2
            exit 1
        fi
        RUN_ARGS+=(-v "${SSH_KEY_FILE}:/run/secrets/ssh/id_ed25519:ro")
    elif [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        RUN_ARGS+=(
            -v "${SSH_AUTH_SOCK}:/run/ssh-agent.sock:ro"
            -e "SSH_AUTH_SOCK=/run/ssh-agent.sock"
        )
    fi

    RUN_ARGS+=("${IMAGE}")

    # Append command args (e.g. "drt d2 status" → "d.rymcg.tech status")
    if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
        RUN_ARGS+=("d.rymcg.tech" "${CMD_ARGS[@]}")
    fi

    echo "## Starting d-rymcg-tech container (${ENGINE})" >&2
    echo "## Config: ${SOPS_CONFIG}" >&2
    echo "## Image:  ${IMAGE}" >&2
    exec "${ENGINE}" "${RUN_ARGS[@]}"
}

###############################################################################
# clean subcommand
###############################################################################

clean_usage() {
    cat <<'EOF'
Usage: drt --clean [OPTIONS] [CONTEXT_NAME]

Remove SOPS config and/or AGE key for a context.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_clean() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) clean_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                clean_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    clean_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine

    if [[ -z "${CONTEXT}" ]]; then
        local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${KEY_DIR}" ]]; then
            for f in "${KEY_DIR}"/*.key; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .key)")
            done
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                local name
                name="$(basename "$f" .sops.env)"
                local found=false
                for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                    if [[ "$c" == "$name" ]]; then found=true; break; fi
                done
                if [[ "$found" == false ]]; then
                    CONTEXTS+=("$name")
                fi
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "Nothing to clean — no contexts found."
            return
        fi
        CONTEXT=$(wizard choose "Select context to clean" "${CONTEXTS[@]}")
    fi

    local CONFIG_FILE="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    local AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    local DELETED=false

    ## Delete SOPS config
    if [[ -f "${CONFIG_FILE}" ]]; then
        if wizard confirm "Delete SOPS config ${CONFIG_FILE}?" no; then
            rm -f "${CONFIG_FILE}"
            echo "Deleted: ${CONFIG_FILE}"
            DELETED=true
        else
            echo "Kept: ${CONFIG_FILE}"
        fi
    else
        echo "No SOPS config found: ${CONFIG_FILE}"
    fi

    ## Delete AGE key
    if [[ -f "${AGE_KEY_FILE}" ]]; then
        if wizard confirm "Delete AGE key ${AGE_KEY_FILE}?" no; then
            rm -f "${AGE_KEY_FILE}"
            echo "Deleted: ${AGE_KEY_FILE}"
            DELETED=true
        else
            echo "Kept: ${AGE_KEY_FILE}"
        fi
    else
        echo "No AGE key found: ${AGE_KEY_FILE}"
    fi

    if [[ "${DELETED}" == true ]]; then
        echo ""
        echo "Clean complete for context '${CONTEXT}'."
    else
        echo ""
        echo "Nothing was deleted."
    fi
}

###############################################################################
# list subcommand
###############################################################################

cmd_list() {
    local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    local CONTEXTS=()

    ## Collect unique context names from keys and configs
    if [[ -d "${KEY_DIR}" ]]; then
        for f in "${KEY_DIR}"/*.key; do
            [[ -f "$f" ]] || continue
            CONTEXTS+=("$(basename "$f" .key)")
        done
    fi
    if [[ -d "${CONFIG_DIR}" ]]; then
        for f in "${CONFIG_DIR}"/*.sops.env; do
            [[ -f "$f" ]] || continue
            local name
            name="$(basename "$f" .sops.env)"
            ## Avoid duplicates
            local found=false
            for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                if [[ "$c" == "$name" ]]; then found=true; break; fi
            done
            if [[ "$found" == false ]]; then
                CONTEXTS+=("$name")
            fi
        done
    fi

    if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
        echo "No contexts found."
        return
    fi

    ## Sort contexts
    local SORTED
    SORTED=$(printf '%s\n' "${CONTEXTS[@]}" | sort)
    CONTEXTS=()
    while IFS= read -r ctx; do
        [[ -n "$ctx" ]] && CONTEXTS+=("$ctx")
    done <<< "$SORTED"

    printf "%-20s %-12s %s\n" "CONTEXT" "KEY" "CONFIG"
    printf "%-20s %-12s %s\n" "-------" "---" "------"
    for ctx in "${CONTEXTS[@]}"; do
        local key_status="missing"
        if [[ -f "${KEY_DIR}/${ctx}.key" ]]; then
            if head -1 "${KEY_DIR}/${ctx}.key" | grep -q '^age-encryption.org'; then
                key_status="encrypted"
            else
                key_status="plaintext!!"
            fi
        fi
        local config_status="missing"
        if [[ -f "${CONFIG_DIR}/${ctx}.sops.env" ]]; then
            config_status="${CONFIG_DIR}/${ctx}.sops.env"
        fi
        printf "%-20s %-12s %s\n" "$ctx" "$key_status" "$config_status"
    done
}

###############################################################################
# extract subcommand
###############################################################################

cmd_extract() {
    if [[ -n "${DRT_IMAGE:-}" ]]; then
        sed "s|@@DRT_IMAGE@@|${DRT_IMAGE}|g" "$(readlink -f "$0")"
    else
        cat "$(readlink -f "$0")"
    fi
}

###############################################################################
# Main dispatch
###############################################################################

ACTION=run
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --init)
            ACTION=init
            shift
            ARGS+=("$@")
            break
            ;;
        --clean)
            ACTION=clean
            shift
            ARGS+=("$@")
            break
            ;;
        --list)
            ACTION=list
            shift
            ;;
        --extract)
            ACTION=extract
            shift
            ;;
        --image)
            IMAGE="$2"
            ARGS+=(--image "$2")
            shift 2
            ;;
        --docker)
            ENGINE=docker
            ARGS+=(--docker)
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "drt ${VERSION}"
            exit 0
            ;;
        -*)
            # Pass through to cmd_run
            ARGS+=("$1")
            shift
            ;;
        *)
            # Positional arg = CONTEXT for run; collect rest too
            ARGS+=("$1")
            shift
            ARGS+=("$@")
            break
            ;;
    esac
done

case "${ACTION}" in
    init)
        cmd_init "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    clean)
        cmd_clean "${ARGS[@]+"${ARGS[@]}"}"
        ;;
    list)
        cmd_list
        ;;
    extract)
        cmd_extract
        ;;
    run)
        if [[ ${#ARGS[@]} -eq 0 ]]; then
            usage
            exit 0
        fi
        cmd_run "${ARGS[@]}"
        ;;
esac

###############################################################################
# How to setup the 'drt' alias for d.rymcg.tech:
# (Do this on your host workstation)
#
# Define a shell alias (add to ~/.bashrc or ~/.zshrc):
#
#   alias drt='bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt)'
#
# When you run e.g. "drt --init myserver", bash expands this to:
#
#   bash <(podman run --rm --pull=never @@DRT_IMAGE@@ drt) --init myserver
#
# The container entrypoint detects "drt" with no args and runs "drt --extract",
# which prints this script to stdout. The process substitution feeds it to
# bash, which executes it with the remaining arguments (--init myserver).
#
# The script itself never touches the container — it runs entirely on the
# host, orchestrating podman/docker to launch containers as needed.
#
# Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
###############################################################################
