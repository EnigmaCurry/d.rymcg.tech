    local LOCAL_ID=""
    if "${ENGINE}" image exists "${IMAGE}" 2>/dev/null; then
        LOCAL_ID=$("${ENGINE}" image inspect "${IMAGE}" --format '{{.Id}}' 2>/dev/null || true)
