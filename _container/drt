                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    edit_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine
    git_auto_pull

    ## Pick context interactively if not provided
    if [[ -z "${CONTEXT}" ]]; then
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .sops.env)")
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "No configs found. Run 'drt --init' first." >&2
            exit 1
        fi
        CONTEXT=$(wizard choose "Select context to edit" "${CONTEXTS[@]}")
    fi

    local SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: config not found: ${SOPS_CONFIG}" >&2
        exit 1
    fi

    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    fi
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key not found: ${AGE_KEY_FILE}" >&2
        exit 1
    fi

    # Decrypt passphrase-protected AGE key in a separate interactive step
    local DEC_DIR=""
    if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
        DEC_DIR=$(mktemp -d)
        cp "${AGE_KEY_FILE}" "${DEC_DIR}/age-key-in"
        echo "## Get ready to enter your AGE key passphrase ..." >&2
        container_run -it --user 0:0 \
            -v "${DEC_DIR}:/tmp/age-work:Z" \
            "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-work/age-key-dec'
        echo "## Passphrase accepted." >&2
        AGE_KEY_FILE="${DEC_DIR}/age-key-dec"
    fi

    # Decrypt to secure temp file
    local EDIT_DIR
    EDIT_DIR=$(mktemp -d)
    local EDIT_FILE="${EDIT_DIR}/${CONTEXT}.env"
    container_run \
        --user 0:0 -i \
        -v "${SOPS_CONFIG}:/tmp/config.sops.env:ro" \
        -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
        -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
        "${IMAGE}" \
        sops decrypt --input-type dotenv --output-type dotenv \
            --filename-override export.env /tmp/config.sops.env > "${EDIT_FILE}"
    chmod 600 "${EDIT_FILE}"

    # Get AGE recipient (public key) for re-encryption
    local AGE_RECIPIENT
    AGE_RECIPIENT=$(container_run \
        --user 0:0 -i \
        -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
        "${IMAGE}" age-keygen -y /run/secrets/age-key 2>/dev/null)
    if [[ -z "${AGE_RECIPIENT}" ]]; then
        echo "Error: could not derive AGE recipient from key" >&2
        rm -rf "${EDIT_DIR}" "${DEC_DIR}"
        exit 1
    fi

    # Save original for diffing
    local ORIG_FILE="${EDIT_DIR}/${CONTEXT}.env.orig"
    cp "${EDIT_FILE}" "${ORIG_FILE}"

    # Open editor
    "${EDITOR:-nano}" "${EDIT_FILE}"

    # Check if file was modified
    if diff -q "${ORIG_FILE}" "${EDIT_FILE}" &>/dev/null; then
        echo "## No changes made, config unchanged." >&2
        rm -rf "${EDIT_DIR}" "${DEC_DIR}"
        exit 0
    fi

    # Show diff and confirm
    echo "" >&2
    echo "## Changes:" >&2
    diff -u "${ORIG_FILE}" "${EDIT_FILE}" >&2 || true
    echo "" >&2
    read -rp "Save changes to ${SOPS_CONFIG}? [y/N] " answer
    if [[ ! "${answer}" =~ ^[Yy]$ ]]; then
        echo "## Changes discarded." >&2
        rm -rf "${EDIT_DIR}" "${DEC_DIR}"
        exit 0
    fi

    # Re-encrypt and overwrite original
    container_run \
        --user 0:0 -i \
        -v "${EDIT_FILE}:/tmp/plaintext.env:ro" \
        -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
        -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
        "${IMAGE}" \
        sops encrypt --input-type dotenv --output-type dotenv \
            --filename-override export.env \
            --age "${AGE_RECIPIENT}" /tmp/plaintext.env > "${SOPS_CONFIG}"

    echo "## Changes encrypted and saved to ${SOPS_CONFIG}" >&2

    rm -rf "${EDIT_DIR}" "${DEC_DIR}"
    git_auto_commit "update context: ${CONTEXT}"
}

###############################################################################
# build subcommand
###############################################################################

DRT_GIT_REPO_DEFAULT="https://github.com/EnigmaCurry/d.rymcg.tech.git"

cmd_build() {
    check_engine

    # Defaults from current image labels, overridable by env/args
    local REPO="${DRT_GIT_REPO:-}"
    if [[ -z "${REPO}" ]]; then
        REPO=$("${ENGINE}" image inspect "${IMAGE}" --format '{{index .Labels "drt.repo"}}' 2>/dev/null || true)
        REPO="${REPO:-${DRT_GIT_REPO_DEFAULT}}"
    fi

    # Priority: DRT_BUILD_BRANCH env > image label > master
    local BRANCH=""
    if [[ -n "${DRT_BUILD_BRANCH:-}" ]]; then
        BRANCH="${DRT_BUILD_BRANCH}"
    else
        BRANCH=$("${ENGINE}" image inspect "${IMAGE}" --format '{{index .Labels "drt.branch"}}' 2>/dev/null || true)
        BRANCH="${BRANCH:-master}"
    fi

    echo "## Building from ${REPO}#${BRANCH} ..." >&2
    _DRT_BUILD_DIR=$(mktemp -d)
    trap 'rm -rf "${_DRT_BUILD_DIR}"' EXIT
    git clone --depth 1 --branch "${BRANCH}" "${REPO}" "${_DRT_BUILD_DIR}/src"
    if [[ ! -f "${_DRT_BUILD_DIR}/src/_container/Dockerfile" ]]; then
        echo "Error: _container/Dockerfile not found on branch '${BRANCH}'." >&2
        echo "Set DRT_BUILD_BRANCH to a branch that has the Dockerfile." >&2
        exit 1
    fi
    "${ENGINE}" build \
        --build-arg "BRANCH=${BRANCH}" \
        --build-arg "GIT_REPO=${REPO}" \
        -f "${_DRT_BUILD_DIR}/src/_container/Dockerfile" \
        -t "${IMAGE}" \
        "${_DRT_BUILD_DIR}/src"
    echo "## Built: ${IMAGE} (branch: ${BRANCH}, repo: ${REPO})" >&2
}

