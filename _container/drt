#!/usr/bin/env bash
## drt — standalone d.rymcg.tech bootstrap tool
## Combines init + run into a single script with no repo dependency.
## Host dependencies: bash, podman (or docker), openssh, coreutils, grep, gawk
## Setup alias:
##   alias drt='bash <(podman run --rm --pull=never --net=none @@DRT_IMAGE@@ drt)'
set -euo pipefail

VERSION="1.0.0"
DEFAULT_IMAGE="${DRT_IMAGE:-@@DRT_IMAGE@@}"
if [[ "${DEFAULT_IMAGE}" == @@*@@ ]]; then
    DEFAULT_IMAGE="localhost/d-rymcg-tech:latest"
fi

###############################################################################
# Shared helpers
###############################################################################

ENGINE=podman
IMAGE="${DEFAULT_IMAGE}"
BUILD=false
NET_MODE=""

check_engine() {
    if ! command -v "${ENGINE}" &>/dev/null; then
        echo "Error: ${ENGINE} not found in PATH" >&2
        echo "Install ${ENGINE} first, or use --docker to use Docker instead." >&2
        exit 1
    fi
}

## Detect working network mode for podman (pasta may be broken on some systems)
## Caches result in ~/.config/d.rymcg.tech/net-mode
detect_net_mode() {
    [[ -n "${NET_MODE}" ]] && return
    [[ "${ENGINE}" != "podman" ]] && return
    local CACHE_FILE="${HOME}/.config/d.rymcg.tech/net-mode"
    if [[ -f "${CACHE_FILE}" ]]; then
        NET_MODE=$(cat "${CACHE_FILE}")
        return
    fi
    echo "## Detecting network mode (one-time check) ..." >&2
    if "${ENGINE}" run --rm --net=pasta --entrypoint "" "${IMAGE}" true 2>/dev/null; then
        NET_MODE=pasta
    elif "${ENGINE}" run --rm --net=slirp4netns --entrypoint "" "${IMAGE}" true 2>/dev/null; then
        NET_MODE=slirp4netns
        echo "## Network: using slirp4netns (pasta unavailable)" >&2
    else
        NET_MODE=host
        echo "## Network: using host (pasta and slirp4netns unavailable)" >&2
    fi
    mkdir -p "$(dirname "${CACHE_FILE}")" 2>/dev/null
    echo "${NET_MODE}" > "${CACHE_FILE}" 2>/dev/null || true
}

## Run a command inside the container, bypassing the entrypoint
## Always runs locally (--context default for docker) to avoid executing on a remote SSH context
container_run() {
    if [[ "${ENGINE}" == "docker" ]]; then
        "${ENGINE}" --context default run --rm --net=none --entrypoint "" "$@"
    else
        "${ENGINE}" run --rm --net=none --entrypoint "" "$@"
    fi
}

## Run script-wizard inside the container interactively
## Uses a named container so we can copy the answer out after it exits
wizard() {
    local cname="wizard-$$-${RANDOM}"
    local answer="/tmp/wizard-answer-${cname}"
    local _ctx=()
    [[ "${ENGINE}" == "docker" ]] && _ctx=(--context default)
    trap '"${ENGINE}" "${_ctx[@]}" rm "${cname}" >/dev/null 2>&1' EXIT
    "${ENGINE}" "${_ctx[@]}" run -it --net=none --name "${cname}" --entrypoint "" \
        -e "TERM=${TERM:-xterm}" -e "WIZARD_ANSWER=${answer}" \
        "${IMAGE}" \
        sh -c 'script-wizard "$@" > "${WIZARD_ANSWER}"' -- "$@" >&2
    local rc=$?
    "${ENGINE}" "${_ctx[@]}" cp "${cname}:${answer}" - | tar -xO
    trap - EXIT
    "${ENGINE}" "${_ctx[@]}" rm "${cname}" >/dev/null
    return $rc
}

## List FIDO2 hidraw devices with human-readable names
## Filters by checking for FIDO usage page (0xF1D0) in the HID report descriptor
## Output: one line per device: "/dev/hidrawN|HID_ID|Device Name"
detect_hidraw_devices() {
    for dev in /dev/hidraw*; do
        [[ -e "$dev" ]] || continue
        local sysdev="/sys/class/hidraw/$(basename "$dev")/device"
        # Check for FIDO usage page (0xF1D0) in report descriptor
        local report_desc="${sysdev}/report_descriptor"
        if [[ -f "${report_desc}" ]]; then
            # FIDO usage page appears as bytes 06 D0 F1 in the HID descriptor
            if ! od -An -tx1 "${report_desc}" 2>/dev/null | tr -d ' \n' | grep -qi '06d0f1'; then
                continue
            fi
        else
            continue
        fi
        local name="" hidid=""
        if [[ -f "${sysdev}/uevent" ]]; then
            name=$(grep '^HID_NAME=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
            hidid=$(grep '^HID_ID=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
        fi
        [[ -z "$name" ]] && name="Unknown"
        echo "${dev}|${hidid}|${name}"
    done
}

## Find hidraw device path by stored HID_ID
## Args: $1 = HID_ID string (e.g. "0003:00001209:00005070")
## Output: /dev/hidrawN path
find_hidraw_by_id() {
    local target_id="$1"
    for dev in /dev/hidraw*; do
        [[ -e "$dev" ]] || continue
        local sysdev="/sys/class/hidraw/$(basename "$dev")/device"
        if [[ -f "${sysdev}/uevent" ]]; then
            local hidid
            hidid=$(grep '^HID_ID=' "${sysdev}/uevent" 2>/dev/null | cut -d= -f2)
            if [[ "$hidid" == "$target_id" ]]; then
                echo "$dev"
                return 0
            fi
        fi
    done
    return 1
}

## Pull from remote if ~/.config/d.rymcg.tech is a git repo with a remote
git_auto_pull() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    [[ -d "${CONFIG_BASE}/.git" ]] || return 0
    local remote
    remote=$(git -C "${CONFIG_BASE}" remote 2>/dev/null | head -1)
    [[ -n "${remote}" ]] || return 0
    echo "## git: fetching from ${remote} ..." >&2
    git -C "${CONFIG_BASE}" fetch "${remote}" 2>/dev/null || {
        echo "## git: fetch failed (network issue?), continuing with local state" >&2
        return 0
    }
    local branch
    branch=$(git -C "${CONFIG_BASE}" branch --show-current 2>/dev/null)
    [[ -n "${branch}" ]] || return 0
    if git -C "${CONFIG_BASE}" rev-parse "${remote}/${branch}" &>/dev/null; then
        if ! git -C "${CONFIG_BASE}" merge --ff-only "${remote}/${branch}" 2>/dev/null; then
            echo "ERROR: config repo has diverged from ${remote}/${branch} — resolve manually with: drt --git" >&2
            exit 1
        fi
        echo "## git: up to date with ${remote}/${branch}" >&2
    fi
}

## Ensure base directory structure for config
ensure_config_dir() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    mkdir -p "${CONFIG_BASE}/keys/sops" "${CONFIG_BASE}/config"
    if [[ ! -f "${CONFIG_BASE}/.gitignore" ]]; then
        cat > "${CONFIG_BASE}/.gitignore" <<'GITIGNORE'
net-mode
keys/*
gumdrop-presets/*
GITIGNORE
    else
        # Ensure newer ignore entries are present in existing .gitignore
        grep -qx 'gumdrop-presets/\*' "${CONFIG_BASE}/.gitignore" 2>/dev/null || \
            echo 'gumdrop-presets/*' >> "${CONFIG_BASE}/.gitignore"
    fi
    if [[ ! -f "${CONFIG_BASE}/keys/.gitkeep" ]]; then
        touch "${CONFIG_BASE}/keys/.gitkeep"
    fi
}

## Auto-commit config changes if ~/.config/d.rymcg.tech is a git repo
git_auto_commit() {
    local msg="$1"
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    [[ -d "${CONFIG_BASE}/.git" ]] || return 0
    echo "## git: staging changes ..." >&2
    git -C "${CONFIG_BASE}" add -A
    if git -C "${CONFIG_BASE}" diff --cached --quiet; then
        echo "## git: no changes to commit" >&2
        return 0
    fi
    if ! git -C "${CONFIG_BASE}" commit -m "${msg}" >/dev/null 2>&1; then
        echo "## git: commit failed — you may need to configure git identity:" >&2
        echo "##   drt --git config user.email \"you@example.com\"" >&2
        echo "##   drt --git config user.name \"Your Name\"" >&2
        return 1
    fi
    echo "## git: committed: ${msg}" >&2
    local remote
    remote=$(git -C "${CONFIG_BASE}" remote 2>/dev/null | head -1)
    if [[ -n "${remote}" ]]; then
        read -rp "## git: push to ${remote}? [Y/n] " answer </dev/tty
        if [[ ! "${answer}" =~ ^[Nn]$ ]]; then
            git -C "${CONFIG_BASE}" push 2>/dev/null && \
                echo "## git: pushed" >&2 || \
                echo "## git: push failed" >&2
        fi
    fi
}

###############################################################################
# Top-level usage
###############################################################################

usage() {
    cat <<'EOF'
drt — standalone d.rymcg.tech bootstrap tool

Usage:
  drt [OPTIONS] CONTEXT [CMD]  Launch container (interactive shell or run CMD)

Options:
  --init [CONTEXT]   Bootstrap AGE key + SOPS config for a context
  --view [CONTEXT]   Decrypt and display SOPS config
  --edit [CONTEXT]   Decrypt, edit in \$EDITOR, and re-encrypt SOPS config
  --clean [CONTEXT]  Remove SOPS config and/or AGE key for a context
  --seal [CONTEXT]   Seal the OpenBao server used by a context
  --unseal [CONTEXT] Unseal the OpenBao server used by a context
  --list             List all contexts (AGE keys and SOPS configs)
  --git-init         Initialize ~/.config/d.rymcg.tech as a git repo
  --git [ARGS]       Run git commands in ~/.config/d.rymcg.tech
  --pull             Pull latest image
  --build            Build image from git (branch from DRT_BUILD_BRANCH or image label)
  --extract          Print this script to stdout (self-extraction)
  --image TAG        Container image (default: localhost/d-rymcg-tech:latest)
  --docker           Use Docker instead of Podman
  --age-key FILE     AGE key file (default: ~/.config/d.rymcg.tech/keys/sops/<context>.key)
  --ssh-key FILE     SSH key file (disables agent forwarding)
  --ssh-timeout SEC  SSH ConnectTimeout in seconds (default: 30)
  --timeout SEC      Command timeout in seconds (default: 300)
  --no-save          Disable save-on-exit
  --controller-port PORT  Host port for request-controller (default: 8084)
  --net MODE         Network mode: pasta, slirp4netns, host (auto-detected)
  --version          Print version
  --help             Show this help
EOF
    echo ""
    echo "One time setup (from registry):"
    if [[ "${IMAGE}" != localhost/* ]]; then
        echo "  ${ENGINE} pull ${IMAGE}"
    fi
    echo "  alias drt='bash <(${ENGINE} run --rm --pull=never --net=none ${IMAGE} drt)'"
    echo ""
    echo "One time setup (build from source):"
    echo "  drt --build            # rebuild from DRT_BUILD_BRANCH or last-built branch"
    echo "  alias drt='bash <(${ENGINE} run --rm --pull=never --net=none localhost/d-rymcg-tech:latest drt)'"
}

###############################################################################
# init subcommand
###############################################################################

init_usage() {
    cat <<'EOF'
Usage: drt --init [OPTIONS] [CONTEXT_NAME]

Bootstrap a new d-rymcg-tech deployment config.

Generates an AGE encryption key (if needed) and creates a SOPS-encrypted
config file for the given context. Only requires Podman (or Docker).

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_init() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) init_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                init_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    init_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine
    git_auto_pull

    ## Context name
    if [[ -z "${CONTEXT}" ]]; then
        CONTEXT=$(wizard ask "Enter the desired context name (SSH host alias)")
    fi

    ensure_config_dir

    ## Check for existing config — load current values as defaults
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    local _EXISTING=""
    if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
        echo "Config already exists: ${CONFIG_DIR}/${CONTEXT}.sops.env"
        echo "Re-running wizard — current values will be used as defaults."
        echo ""
    fi

    ## Ensure AGE key (one per context)
    local AGE_KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local AGE_KEY_FILE="${AGE_KEY_DIR}/${CONTEXT}.key"
    local PUBKEY
    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "No AGE key found for context '${CONTEXT}'"
        mkdir -p "${AGE_KEY_DIR}"

        local KEY_PROTECTION
        KEY_PROTECTION=$(wizard choose "Select AGE key protection method" \
            "Passphrase protected key file (must have: key AND passphrase)" \
            "FIDO2 hardware token + cold storage key (must have: token+PIN OR cold storage key)" \
            "No protection")

        case "${KEY_PROTECTION}" in
            "Passphrase protected key file (must have: key AND passphrase)")
                echo "Generating a new AGE keypair..."
                container_run "${IMAGE}" age-keygen > "${AGE_KEY_FILE}"
                chmod 600 "${AGE_KEY_FILE}"
                PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)
                local ENC_DIR
                ENC_DIR=$(mktemp -d)
                cp "${AGE_KEY_FILE}" "${ENC_DIR}/age-key-in"
                local ENCRYPTED="${ENC_DIR}/age-key-enc"
                if container_run -it --user 0:0 \
                    -v "${ENC_DIR}:/tmp/age-work:Z" \
                    "${IMAGE}" sh -c 'age -p /tmp/age-work/age-key-in > /tmp/age-work/age-key-enc' \
                    && [[ -s "${ENCRYPTED}" ]]; then
                    mv "${ENCRYPTED}" "${AGE_KEY_FILE}"
                    chmod 600 "${AGE_KEY_FILE}"
                    echo "AGE key created (passphrase-protected): ${AGE_KEY_FILE}"
                    rm -rf "${ENC_DIR}"
                else
                    rm -rf "${ENC_DIR}"
                    rm -f "${AGE_KEY_FILE}"
                    echo "Error: passphrase encryption failed — no key was saved." >&2
                    exit 1
                fi
                ;;
            "FIDO2 hardware token + cold storage key (must have: token+PIN OR cold storage key)")
                local ALL_PUBKEYS=()
                local FIDO2_ID_FILE="${AGE_KEY_DIR}/${CONTEXT}.fido2"
                > "${AGE_KEY_FILE}"   # start with empty key file
                > "${FIDO2_ID_FILE}"  # start with empty device list
                chmod 600 "${AGE_KEY_FILE}" "${FIDO2_ID_FILE}"

                # Enroll a single FIDO2 hardware key
                echo ""
                echo "Detecting FIDO2 devices..."
                local FIDO2_DEVICES=() FIDO2_IDS=() FIDO2_DEVPATHS=()
                while IFS='|' read -r devpath hidid devname; do
                    FIDO2_DEVICES+=("${devname} (${devpath})")
                    FIDO2_IDS+=("${hidid}")
                    FIDO2_DEVPATHS+=("${devpath}")
                done < <(detect_hidraw_devices)

                if [[ ${#FIDO2_DEVICES[@]} -eq 0 ]]; then
                    echo "Error: no FIDO2 devices detected in /dev/hidraw*" >&2
                    echo "  Ensure your FIDO2 key is plugged in and you have read access to /dev/hidraw*" >&2
                    exit 1
                fi

                local SELECTED_IDX=0
                local SELECTED
                SELECTED=$(wizard choose "Select FIDO2 device" "${FIDO2_DEVICES[@]}")
                for i in "${!FIDO2_DEVICES[@]}"; do
                    if [[ "${FIDO2_DEVICES[$i]}" == "${SELECTED}" ]]; then
                        SELECTED_IDX=$i
                        break
                    fi
                done

                local FIDO2_DEV="${FIDO2_DEVPATHS[$SELECTED_IDX]}"
                local FIDO2_HID_ID="${FIDO2_IDS[$SELECTED_IDX]}"

                echo "Generating FIDO2 AGE identity on ${FIDO2_DEV}..."
                echo "You will be prompted for your FIDO2 PIN and to touch the key."
                local FIDO2_DIR
                FIDO2_DIR=$(mktemp -d)
                if container_run -it --user 0:0 \
                    --security-opt label=disable \
                    --device "${FIDO2_DEV}" \
                    -v "${FIDO2_DIR}:/tmp/fido2-work:Z" \
                    "${IMAGE}" sh -c 'age-plugin-fido2-hmac -g > /tmp/fido2-work/identity' \
                    && [[ -s "${FIDO2_DIR}/identity" ]]; then
                    cat "${FIDO2_DIR}/identity" >> "${AGE_KEY_FILE}"
                    echo "" >> "${AGE_KEY_FILE}"
                    local _this_pubkey
                    _this_pubkey=$(grep -o 'age1[a-z0-9]*' "${FIDO2_DIR}/identity" | head -1)
                    ALL_PUBKEYS+=("${_this_pubkey}")
                    echo "${FIDO2_HID_ID}" >> "${FIDO2_ID_FILE}"
                    echo "FIDO2 key enrolled (${_this_pubkey:0:20}...)"
                else
                    rm -rf "${FIDO2_DIR}"
                    echo "Error: FIDO2 key generation failed." >&2
                    exit 1
                fi
                rm -rf "${FIDO2_DIR}"

                # Prompt for cold storage backup public key
                echo ""
                echo "Enter the public key of your cold storage AGE key."
                echo "This key will be added as a SOPS recipient for disaster recovery."
                echo "Generate one on another machine with: age-keygen"
                local COLD_STORAGE_PUBKEY
                COLD_STORAGE_PUBKEY=$(wizard ask "Cold storage public key (age1...)")
                if [[ ! "${COLD_STORAGE_PUBKEY}" =~ ^age1[a-z0-9]+$ ]]; then
                    echo "Error: invalid AGE public key (must start with age1)" >&2
                    exit 1
                fi
                ALL_PUBKEYS+=("${COLD_STORAGE_PUBKEY}")
                echo "Cold storage backup key added as recipient."

                # Join all public keys with commas for SOPS
                PUBKEY=$(IFS=,; echo "${ALL_PUBKEYS[*]}")
                echo ""
                echo "FIDO2 identity created: ${AGE_KEY_FILE}"
                echo "Device ID stored: ${FIDO2_ID_FILE}"
                echo "SOPS recipients: FIDO2 + cold storage backup"
                ;;
            "No protection")
                echo "Generating a new AGE keypair..."
                container_run "${IMAGE}" age-keygen > "${AGE_KEY_FILE}"
                chmod 600 "${AGE_KEY_FILE}"
                PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)
                echo "AGE key created: ${AGE_KEY_FILE}"
                ;;
        esac
    else
        echo "Using existing AGE key: ${AGE_KEY_FILE}"
        ## Extract public key — if encrypted, need to decrypt first
        local _KEY_IS_ENCRYPTED=false
        if head -1 "${AGE_KEY_FILE}" | grep -q '^age-encryption.org'; then
            _KEY_IS_ENCRYPTED=true
            local DEC_DIR
            DEC_DIR=$(mktemp -d)
            cp "${AGE_KEY_FILE}" "${DEC_DIR}/age-key-in"
            ## If existing config exists, decrypt it in the same container run (one passphrase prompt)
            ## Only the pubkey and decrypted config are written to host — never the private key
            if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
                cp "${CONFIG_DIR}/${CONTEXT}.sops.env" "${DEC_DIR}/config.sops.env"
                container_run -it --user 0:0 \
                    -v "${DEC_DIR}:/tmp/age-work:Z" \
                    "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-key-dec && \
                        grep -o "age1[a-z0-9]*" /tmp/age-key-dec > /tmp/age-work/pubkey && \
                        SOPS_AGE_KEY_FILE=/tmp/age-key-dec sops decrypt \
                        --input-type dotenv --output-type dotenv \
                        --filename-override export.env /tmp/age-work/config.sops.env \
                        > /tmp/age-work/config-decrypted 2>/dev/null || true && \
                        chmod 644 /tmp/age-work/pubkey /tmp/age-work/config-decrypted 2>/dev/null || true'
            else
                container_run -it --user 0:0 \
                    -v "${DEC_DIR}:/tmp/age-work:Z" \
                    "${IMAGE}" sh -c 'age -d /tmp/age-work/age-key-in > /tmp/age-key-dec && \
                        grep -o "age1[a-z0-9]*" /tmp/age-key-dec > /tmp/age-work/pubkey && \
                        chmod 644 /tmp/age-work/pubkey'
            fi
            echo "## Passphrase accepted." >&2
            PUBKEY=$(head -1 "${DEC_DIR}/pubkey")
            ## DEC_DIR cleanup happens after config decryption below, or now if no config
            if [[ ! -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
                rm -rf "${DEC_DIR}"
            fi
        else
            PUBKEY=$(grep -o 'age1[a-z0-9]*' "${AGE_KEY_FILE}" | head -1)
            echo "WARNING: AGE key is NOT password-protected."
        fi
    fi
    echo "AGE public key: ${PUBKEY}"
    echo ""

    ## If existing config, decrypt it to use values as defaults
    local _CUR_SSH_HOST="" _CUR_SSH_PORT="" _CUR_SSH_USER="" _CUR_KNOWN_HOSTS=""
    local _CUR_BAO_ADDR="" _CUR_BAO_ROLE_ID="" _CUR_BAO_SECRET_ID=""
    local _CUR_BAO_SSH_MOUNT="" _CUR_BAO_SSH_ROLE="" _CUR_BAO_AUTH_PATH=""
    local _CUR_BAO_AGE_KEY_PATH="" _CUR_BAO_KV_MOUNT="" _CUR_BAO_NAMESPACE=""
    local _CUR_BAO_CACERT="" _CUR_BAO_CLIENT_CERT="" _CUR_BAO_CLIENT_KEY=""
    local _EXISTING=""
    if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
        echo "## Decrypting existing config for defaults ..." >&2
        if [[ "${_KEY_IS_ENCRYPTED}" == true ]]; then
            ## Already decrypted during key extraction
            if [[ -s "${DEC_DIR}/config-decrypted" ]]; then
                _EXISTING=$(cat "${DEC_DIR}/config-decrypted")
            else
                echo "## Warning: could not decrypt existing config (ls ${DEC_DIR}):" >&2
                ls -la "${DEC_DIR}" >&2 || true
            fi
            rm -rf "${DEC_DIR}"
        elif [[ "${_KEY_IS_ENCRYPTED}" != true ]]; then
            ## Key is plaintext, no passphrase needed
            _EXISTING=$(container_run \
                --user 0:0 -i \
                -v "${CONFIG_DIR}/${CONTEXT}.sops.env:/tmp/config.sops.env:ro" \
                -v "${AGE_KEY_FILE}:/run/secrets/age-key:ro" \
                -e "SOPS_AGE_KEY_FILE=/run/secrets/age-key" \
                "${IMAGE}" \
                sops decrypt --input-type dotenv --output-type dotenv \
                    --filename-override export.env /tmp/config.sops.env 2>/dev/null) || true
        fi
        if [[ -n "${_EXISTING}" ]]; then
            _CUR_SSH_HOST=$(echo "${_EXISTING}" | grep '^SSH_HOST=' | cut -d= -f2- || true)
            _CUR_SSH_PORT=$(echo "${_EXISTING}" | grep '^SSH_PORT=' | cut -d= -f2- || true)
            _CUR_SSH_USER=$(echo "${_EXISTING}" | grep '^SSH_USER=' | cut -d= -f2- || true)
            _CUR_KNOWN_HOSTS=$(echo "${_EXISTING}" | grep '^SSH_KNOWN_HOSTS=' | cut -d= -f2- || true)
            _CUR_BAO_ADDR=$(echo "${_EXISTING}" | grep '^BAO_ADDR=' | cut -d= -f2- || true)
            _CUR_BAO_ROLE_ID=$(echo "${_EXISTING}" | grep '^BAO_ROLE_ID=' | cut -d= -f2- || true)
            _CUR_BAO_SECRET_ID=$(echo "${_EXISTING}" | grep '^BAO_SECRET_ID=' | cut -d= -f2- || true)
            _CUR_BAO_SSH_MOUNT=$(echo "${_EXISTING}" | grep '^BAO_SSH_MOUNT=' | cut -d= -f2- || true)
            _CUR_BAO_SSH_ROLE=$(echo "${_EXISTING}" | grep '^BAO_SSH_ROLE=' | cut -d= -f2- || true)
            _CUR_BAO_AUTH_PATH=$(echo "${_EXISTING}" | grep '^BAO_AUTH_PATH=' | cut -d= -f2- || true)
            _CUR_BAO_AGE_KEY_PATH=$(echo "${_EXISTING}" | grep '^BAO_AGE_KEY_PATH=' | cut -d= -f2- || true)
            _CUR_BAO_KV_MOUNT=$(echo "${_EXISTING}" | grep '^BAO_KV_MOUNT=' | cut -d= -f2- || true)
            _CUR_BAO_NAMESPACE=$(echo "${_EXISTING}" | grep '^BAO_NAMESPACE=' | cut -d= -f2- || true)
            _CUR_BAO_CACERT=$(echo "${_EXISTING}" | grep '^BAO_CACERT=' | cut -d= -f2- || true)
            _CUR_BAO_CLIENT_CERT=$(echo "${_EXISTING}" | grep '^BAO_CLIENT_CERT=' | cut -d= -f2- || true)
            _CUR_BAO_CLIENT_KEY=$(echo "${_EXISTING}" | grep '^BAO_CLIENT_KEY=' | cut -d= -f2- || true)
        fi
    fi

    ## SSH details — pre-fill from existing config, then ssh config, then defaults
    local SSH_CONFIG SSH_HOST SSH_PORT SSH_USER
    SSH_CONFIG=$(ssh -G "${CONTEXT}" 2>/dev/null || true)
    local _SSH_HOST _SSH_PORT _SSH_USER
    _SSH_HOST=$(echo "${SSH_CONFIG}" | awk '/^hostname / {print $2}')
    _SSH_PORT=$(echo "${SSH_CONFIG}" | awk '/^port / {print $2; exit}')
    _SSH_USER=$(echo "${SSH_CONFIG}" | awk '/^user / {print $2}')

    ## Existing config takes priority over ssh config
    [[ -n "${_CUR_SSH_HOST}" ]] && _SSH_HOST="${_CUR_SSH_HOST}"
    [[ -n "${_CUR_SSH_PORT}" ]] && _SSH_PORT="${_CUR_SSH_PORT}"
    [[ -n "${_CUR_SSH_USER}" ]] && _SSH_USER="${_CUR_SSH_USER}"

    ## Don't default to the context name as the hostname
    [[ "${_SSH_HOST}" == "${CONTEXT}" ]] && _SSH_HOST=""
    SSH_HOST=$(wizard ask "Enter SSH hostname or IP address" "${_SSH_HOST}")
    SSH_PORT=$(wizard ask "Enter SSH port" "${_SSH_PORT:-22}")
    SSH_USER=$(wizard ask "Enter SSH user" "${_SSH_USER:-root}")

    ## SSH key scan — preserve existing known_hosts unless user re-scans
    local KNOWN_HOSTS=""
    if wizard confirm "Run ssh-keyscan now for ${SSH_HOST}:${SSH_PORT}?" no; then
        echo ""
        echo "Running ssh-keyscan for ${SSH_HOST}:${SSH_PORT}..."
        KNOWN_HOSTS=$(ssh-keyscan -p "${SSH_PORT}" "${SSH_HOST}" 2>/dev/null || true)
        if [[ -z "${KNOWN_HOSTS}" ]]; then
            echo "ssh-keyscan failed for ${SSH_HOST}:${SSH_PORT}"
        fi
    fi
    if [[ -z "${KNOWN_HOSTS}" && -n "${_CUR_KNOWN_HOSTS}" ]]; then
        echo "Keeping existing SSH known_hosts."
    elif [[ -z "${KNOWN_HOSTS}" ]]; then
        echo "  You can set SSH_KNOWN_HOSTS later, or set SSH_KEY_SCAN=false to skip verification."
    else
        echo "SSH host keys collected."
    fi

    ## Optional OpenBao SSH certificate signing
    local BAO_ADDR="" BAO_ROLE_ID="" BAO_SECRET_ID="" BAO_SSH_MOUNT="" BAO_SSH_ROLE=""
    local BAO_AUTH_PATH="" BAO_AGE_KEY_PATH="" BAO_KV_MOUNT="" BAO_NAMESPACE=""
    local BAO_CACERT="" BAO_CLIENT_CERT="" BAO_CLIENT_KEY=""
    local _bao_default=no
    [[ -n "${_CUR_BAO_ADDR}" ]] && _bao_default=yes
    if wizard confirm "Configure OpenBao SSH certificate signing?" "${_bao_default}"; then
        BAO_ADDR=$(wizard ask "Enter OpenBao server URL (e.g., https://bao.example.com:443)" "${_CUR_BAO_ADDR}")
        BAO_ROLE_ID=$(wizard ask "Enter OpenBao BAO_ROLE_ID" "${_CUR_BAO_ROLE_ID}")
        BAO_SECRET_ID=$(wizard ask "Enter OpenBao BAO_SECRET_ID" "${_CUR_BAO_SECRET_ID}")
        BAO_SSH_MOUNT=$(wizard ask "Enter SSH engine mount" "${_CUR_BAO_SSH_MOUNT:-ssh-client-signer}")
        BAO_SSH_ROLE=$(wizard ask "Enter SSH signing role" "${_CUR_BAO_SSH_ROLE:-woodpecker-short-lived}")
        BAO_AUTH_PATH=$(wizard ask "Enter auth path" "${_CUR_BAO_AUTH_PATH:-auth/approle}")

        local _tls_default=no
        [[ -n "${_CUR_BAO_CLIENT_CERT}" ]] && _tls_default=yes
        if wizard confirm "Configure OpenBao TLS client certificates?" "${_tls_default}"; then
            if [[ -n "${_CUR_BAO_CACERT}" ]]; then
                if wizard confirm "Keep existing CA certificate?" yes; then
                    BAO_CACERT="${_CUR_BAO_CACERT}"
                else
                    echo "Paste CA certificate PEM, then press Ctrl+D:"
                    BAO_CACERT=$(cat | base64 -w0)
                fi
            else
                echo "Paste CA certificate PEM, then press Ctrl+D (leave blank if using a trusted CA like Let's Encrypt):"
                BAO_CACERT=$(cat | base64 -w0)
            fi
            if [[ -n "${_CUR_BAO_CLIENT_CERT}" ]]; then
                if wizard confirm "Keep existing client certificate?" yes; then
                    BAO_CLIENT_CERT="${_CUR_BAO_CLIENT_CERT}"
                    BAO_CLIENT_KEY="${_CUR_BAO_CLIENT_KEY}"
                else
                    echo "Paste client certificate PEM (may include chain), then press Ctrl+D:"
                    BAO_CLIENT_CERT=$(cat | base64 -w0)
                    echo "Paste client private key PEM, then press Ctrl+D:"
                    BAO_CLIENT_KEY=$(cat | base64 -w0)
                fi
            else
                echo ""
                echo "Paste client certificate PEM (may include chain), then press Ctrl+D:"
                BAO_CLIENT_CERT=$(cat | base64 -w0)
                echo ""
                echo "Paste client private key PEM, then press Ctrl+D:"
                BAO_CLIENT_KEY=$(cat | base64 -w0)
            fi
        fi

        local _ns_default=no
        [[ -n "${_CUR_BAO_NAMESPACE}" ]] && _ns_default=yes
        if wizard confirm "Configure OpenBao namespace?" "${_ns_default}"; then
            BAO_NAMESPACE=$(wizard ask "Enter OpenBao namespace" "${_CUR_BAO_NAMESPACE}")
        fi
    fi

    ## Create SOPS config
    local PLAINTEXT="## SSH
SSH_HOST=${SSH_HOST}
SSH_USER=${SSH_USER}
SSH_PORT=${SSH_PORT}"
    if [[ -n "${KNOWN_HOSTS}" ]]; then
        local SSH_KNOWN_HOSTS
        SSH_KNOWN_HOSTS=$(echo "${KNOWN_HOSTS}" | base64 -w0)
        PLAINTEXT="${PLAINTEXT}
SSH_KNOWN_HOSTS=${SSH_KNOWN_HOSTS}"
    elif [[ -n "${_CUR_KNOWN_HOSTS}" ]]; then
        PLAINTEXT="${PLAINTEXT}
SSH_KNOWN_HOSTS=${_CUR_KNOWN_HOSTS}"
    fi

    ## Append OpenBao vars if configured
    if [[ -n "${BAO_ADDR}" ]]; then
        PLAINTEXT="${PLAINTEXT}
## OpenBao
BAO_ADDR=${BAO_ADDR}
BAO_ROLE_ID=${BAO_ROLE_ID}
BAO_SECRET_ID=${BAO_SECRET_ID}
BAO_SSH_MOUNT=${BAO_SSH_MOUNT}
BAO_SSH_ROLE=${BAO_SSH_ROLE}
BAO_AUTH_PATH=${BAO_AUTH_PATH}"
        [[ -n "${BAO_AGE_KEY_PATH}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_AGE_KEY_PATH=${BAO_AGE_KEY_PATH}"
        [[ -n "${BAO_KV_MOUNT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_KV_MOUNT=${BAO_KV_MOUNT}"
        [[ -n "${BAO_NAMESPACE}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_NAMESPACE=${BAO_NAMESPACE}"
        [[ -n "${BAO_CACERT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CACERT=${BAO_CACERT}"
        [[ -n "${BAO_CLIENT_CERT}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CLIENT_CERT=${BAO_CLIENT_CERT}"
        [[ -n "${BAO_CLIENT_KEY}" ]] && PLAINTEXT="${PLAINTEXT}
BAO_CLIENT_KEY=${BAO_CLIENT_KEY}"
    fi

    ## Preserve existing project vars that --init doesn't manage
    if [[ -n "${_EXISTING}" ]]; then
        while IFS= read -r line || [[ -n "${line}" ]]; do
            [[ -z "${line}" ]] && continue
            # Skip comment headers managed by --init
            [[ "${line}" == "## SSH" || "${line}" == "## OpenBao" ]] && continue
            if [[ "${line}" == *=* && "${line}" != "#"* ]]; then
                local _key="${line%%=*}"
                case "${_key}" in
                    SSH_HOST|SSH_USER|SSH_PORT|SSH_KNOWN_HOSTS) continue;;
                    BAO_ADDR|BAO_ROLE_ID|BAO_SECRET_ID|BAO_SSH_MOUNT|BAO_SSH_ROLE) continue;;
                    BAO_AUTH_PATH|BAO_AGE_KEY_PATH|BAO_KV_MOUNT|BAO_NAMESPACE) continue;;
                    BAO_CACERT|BAO_CLIENT_CERT|BAO_CLIENT_KEY) continue;;
                esac
            fi
            PLAINTEXT+=$'\n'"${line}"
        done <<< "${_EXISTING}"
    fi

    mkdir -p "${CONFIG_DIR}"
    if [[ -f "${CONFIG_DIR}/${CONTEXT}.sops.env" ]]; then
        ## Existing config: use sops edit to only re-encrypt changed values
        local _INIT_WORK
        _INIT_WORK=$(mktemp -d)
        echo "${PLAINTEXT}" > "${_INIT_WORK}/new-plain.env"
        cp "${AGE_KEY_FILE}" "${_INIT_WORK}/age-key-in"
        cp "${CONFIG_DIR}/${CONTEXT}.sops.env" "${_INIT_WORK}/config.sops.env"
        container_run -it --user 0:0 \
            -v "${_INIT_WORK}:/tmp/init-work:Z" \
            "${IMAGE}" sh -c '
                if head -1 /tmp/init-work/age-key-in | grep -q "^age-encryption.org"; then
                    age -d /tmp/init-work/age-key-in > /tmp/age-key-dec
                else
                    cp /tmp/init-work/age-key-in /tmp/age-key-dec
                fi
                export SOPS_AGE_KEY_FILE=/tmp/age-key-dec
                EDITOR="cp /tmp/init-work/new-plain.env" sops \
                    --input-type dotenv --output-type dotenv \
                    /tmp/init-work/config.sops.env
                chmod 644 /tmp/init-work/config.sops.env'
        cp "${_INIT_WORK}/config.sops.env" "${CONFIG_DIR}/${CONTEXT}.sops.env"
        rm -rf "${_INIT_WORK}"
    else
        ## New config: encrypt from scratch
        echo "${PLAINTEXT}" | container_run -i \
            -e "PUBKEY=${PUBKEY}" \
            "${IMAGE}" \
            sh -c 'cat > /tmp/plain.env && sops encrypt \
                --input-type dotenv --output-type dotenv \
                --filename-override export.env \
                --age "${PUBKEY}" /tmp/plain.env' \
            > "${CONFIG_DIR}/${CONTEXT}.sops.env"
    fi

    echo ""
    echo "Config saved to ${CONFIG_DIR}/${CONTEXT}.sops.env"
    echo ""
    echo "Init complete for context '${CONTEXT}'."
    echo ""
    echo "IMPORTANT: Back up these things:"
    echo "  1) AGE key:     ${AGE_KEY_FILE}"
    if [[ -f "${AGE_KEY_DIR}/${CONTEXT}.fido2" ]]; then
        echo "  2) FIDO2 device: your hardware key is required for decryption"
    else
        echo "  2) Passphrase:   remember or store the passphrase you chose"
    fi
    echo "  3) SOPS config: ${CONFIG_DIR}/${CONTEXT}.sops.env"
    echo ""
    echo "Without the AGE key and its protection factor, your encrypted config"
    echo "cannot be decrypted. If you are keeping ~/.config/d.rymcg.tech as a git"
    echo "repo, the SOPS config is tracked but AGE keys are excluded by"
    echo ".gitignore and must be backed up separately. You can keep all your"
    echo "configs in one repo, but each context requires its own AGE key."
    if [[ -n "${_EXISTING}" ]]; then
        git_auto_commit "update context: ${CONTEXT}"
    else
        git_auto_commit "init context: ${CONTEXT}"
    fi
    echo ""
    echo "Next steps:"
    echo "  drt ${CONTEXT}"
}

###############################################################################
# run subcommand
###############################################################################

run_usage() {
    usage
}

cmd_run() {
    local AGE_KEY_FILE=""
    local SSH_KEY_FILE=""
    local SAVE_ON_EXIT=true
    local VERBOSE=false
    local SOPS_CONFIG=""
    local CMD_ARGS=()
    local CONTROLLER_PORT="${DRT_CONTROLLER_PORT:-8084}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --net) NET_MODE="$2"; shift 2 ;;
            --age-key) AGE_KEY_FILE="$2"; shift 2 ;;
            --ssh-key) SSH_KEY_FILE="$2"; shift 2 ;;
            --no-save) SAVE_ON_EXIT=false; shift ;;
            --ssh-timeout) SSH_CONNECT_TIMEOUT="$2"; export SSH_CONNECT_TIMEOUT; shift 2 ;;
            --timeout) TIMEOUT="$2"; export TIMEOUT; shift 2 ;;
            --verbose|-v) VERBOSE=true; shift ;;
            --controller-port) CONTROLLER_PORT="$2"; shift 2 ;;
            --help) run_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                run_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${SOPS_CONFIG}" ]]; then
                    SOPS_CONFIG="$1"
                    shift
                else
                    # Second positional arg = start of command to run
                    CMD_ARGS=("$1")
                    shift
                    CMD_ARGS+=("$@")
                    break
                fi
                ;;
        esac
    done

    if [[ -z "${SOPS_CONFIG}" ]]; then
        echo "Error: CONTEXT_OR_FILE is required" >&2
        echo "" >&2
        run_usage >&2
        exit 1
    fi

    check_engine
    detect_net_mode
    git_auto_pull
    echo "## Resolving context: ${SOPS_CONFIG}" >&2

    # If argument is a bare context name (no slashes, no .sops.env suffix),
    # resolve to ~/.config/d.rymcg.tech/config/<context>.sops.env
    # and default the AGE key to the per-context key
    if [[ "${SOPS_CONFIG}" != */* && "${SOPS_CONFIG}" != *.sops.env ]]; then
        local CONTEXT_NAME="${SOPS_CONFIG}"
        SOPS_CONFIG="${HOME}/.config/d.rymcg.tech/config/${CONTEXT_NAME}.sops.env"
        if [[ -z "${AGE_KEY_FILE}" ]]; then
            AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT_NAME}.key"
        fi
    fi

    # Fall back to legacy default if no key resolved yet
    if [[ -z "${AGE_KEY_FILE}" ]]; then
        AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"
    fi

    # Resolve to absolute path
    if [[ ! -f "${SOPS_CONFIG}" ]]; then
        echo "Error: SOPS config file not found: ${SOPS_CONFIG}" >&2
        echo "  Run 'drt --init' to create one." >&2
        exit 1
    fi
    SOPS_CONFIG="$(realpath "${SOPS_CONFIG}")"

    if [[ ! -f "${AGE_KEY_FILE}" ]]; then
        echo "Error: AGE key file not found: ${AGE_KEY_FILE}" >&2
        echo "  Use --age-key to specify a different path" >&2
        exit 1
    fi
    echo "## AGE key: ${AGE_KEY_FILE}" >&2
    echo "## SOPS config: ${SOPS_CONFIG}" >&2

    local CONTAINER_CONFIG_DIR=/home/user/.config/d.rymcg.tech
    local SOPS_BASENAME
    SOPS_BASENAME="$(basename "${SOPS_CONFIG}")"

    # Passphrase-protected keys: temp copy at 644 for bind mount into main
    # container (which has -it for the passphrase prompt). The passphrase
    # is the real secret, not the encrypted file.
    # Plain-text keys: pass content directly via SOPS_AGE_KEY env var.
    local RUN_ARGS=(
        run --rm -it --pull=never
        --security-opt label=disable
        -e "HOST_UID=$(id -u)"
        -e "HOST_GID=$(id -g)"
        -e "SOPS_CONFIG_FILE=${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${SOPS_CONFIG}:${CONTAINER_CONFIG_DIR}/${SOPS_BASENAME}"
        -v "${AGE_KEY_FILE}:${CONTAINER_CONFIG_DIR}/age-key:ro"
        -e "SOPS_AGE_KEY_FILE=${CONTAINER_CONFIG_DIR}/age-key"
    )

    # FIDO2: pass through hardware key device if this context uses a FIDO2 identity
    local AGE_KEY_DIR
    AGE_KEY_DIR="$(dirname "${AGE_KEY_FILE}")"
    if [[ -n "${CONTEXT_NAME:-}" ]] && grep -q 'AGE-PLUGIN-FIDO2-HMAC' "${AGE_KEY_FILE}" 2>/dev/null; then
        local FIDO2_ID_FILE="${AGE_KEY_DIR}/${CONTEXT_NAME}.fido2"
        local FIDO2_DEV=""

        # Try stored HID_IDs first
        if [[ -f "${FIDO2_ID_FILE}" ]]; then
            local _fido2_id
            while IFS= read -r _fido2_id; do
                [[ -z "${_fido2_id}" ]] && continue
                FIDO2_DEV=$(find_hidraw_by_id "${_fido2_id}") && break
            done < "${FIDO2_ID_FILE}"
        fi

        # Fall back to interactive device selection
        if [[ -z "${FIDO2_DEV}" ]]; then
            echo "## FIDO2: no stored device found, scanning..." >&2
            local _FIDO2_DEVICES=() _FIDO2_DEVPATHS=()
            while IFS='|' read -r devpath hidid devname; do
                _FIDO2_DEVICES+=("${devname} (${devpath})")
                _FIDO2_DEVPATHS+=("${devpath}")
            done < <(detect_hidraw_devices)

            if [[ ${#_FIDO2_DEVICES[@]} -eq 0 ]]; then
                echo "Error: no FIDO2 devices detected" >&2
                echo "  Ensure one of your FIDO2 keys is plugged in" >&2
                exit 1
            fi

            local _SELECTED_IDX=0 _SELECTED
            _SELECTED=$(wizard choose "Select FIDO2 device" "${_FIDO2_DEVICES[@]}")
            for i in "${!_FIDO2_DEVICES[@]}"; do
                if [[ "${_FIDO2_DEVICES[$i]}" == "${_SELECTED}" ]]; then
                    _SELECTED_IDX=$i
                    break
                fi
            done
            FIDO2_DEV="${_FIDO2_DEVPATHS[$_SELECTED_IDX]}"
        fi

        echo "## FIDO2: passing through ${FIDO2_DEV}" >&2
        RUN_ARGS+=(--device "${FIDO2_DEV}")
    fi

    if [[ -n "${NET_MODE}" ]]; then
        RUN_ARGS+=(--net="${NET_MODE}")
    fi

    if [[ "${SAVE_ON_EXIT}" == true ]]; then
        RUN_ARGS+=(-e "SOPS_SAVE_ON_EXIT=true")
    fi

    if [[ "${VERBOSE}" == true ]]; then
        RUN_ARGS+=(-e "DRT_VERBOSE=true")
    fi

    # Forward host environment overrides into the container
    TIMEOUT="${TIMEOUT:-300}"; export TIMEOUT
    local passthrough_vars=(SSH_KEY_SCAN SSH_CONNECT_TIMEOUT TIMEOUT SSH_HOST SSH_USER SSH_PORT DOCKER_CONTEXT PROJECTS
        BAO_ADDR BAO_ROLE_ID BAO_SECRET_ID BAO_AGE_KEY_PATH BAO_SSH_MOUNT
        BAO_SSH_ROLE BAO_AUTH_PATH BAO_KV_MOUNT BAO_NAMESPACE
        BAO_CACERT BAO_CLIENT_CERT BAO_CLIENT_KEY BAO_SKIP)
    for var in "${passthrough_vars[@]}"; do
        if [[ -n "${!var:-}" ]]; then
            RUN_ARGS+=(-e "${var}=${!var}")
        fi
    done

    # SSH: forward agent or mount key file
    if [[ -n "${SSH_KEY_FILE}" ]]; then
        SSH_KEY_FILE="$(realpath "${SSH_KEY_FILE}")"
        if [[ ! -f "${SSH_KEY_FILE}" ]]; then
            echo "Error: SSH key file not found: ${SSH_KEY_FILE}" >&2
            exit 1
        fi
        echo "## SSH: mounting key file ${SSH_KEY_FILE}" >&2
        RUN_ARGS+=(-v "${SSH_KEY_FILE}:/run/secrets/ssh/id_ed25519:ro")
    elif [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        echo "## SSH: forwarding agent (${SSH_AUTH_SOCK})" >&2
        RUN_ARGS+=(
            -v "${SSH_AUTH_SOCK}:/run/ssh-agent.sock:ro"
            -e "SSH_AUTH_SOCK=/run/ssh-agent.sock"
        )
    else
        echo "## SSH: no key file or agent; container will generate a key" >&2
    fi

    # Port mapping for request-controller
    local _is_controller=false
    for _arg in "${CMD_ARGS[@]+"${CMD_ARGS[@]}"}"; do
        if [[ "${_arg}" == "request-controller" ]]; then
            _is_controller=true
            break
        fi
    done
    if [[ "${_is_controller}" == true ]]; then
        RUN_ARGS+=(-p "${CONTROLLER_PORT}:8084")
    fi

    RUN_ARGS+=("${IMAGE}")

    # Append command args (e.g. "drt d2 status" → "d.rymcg.tech status")
    if [[ ${#CMD_ARGS[@]} -gt 0 ]]; then
        RUN_ARGS+=("d.rymcg.tech" "${CMD_ARGS[@]}")
    fi

    echo "## Starting d-rymcg-tech container (${ENGINE})" >&2
    echo "## Config: ${SOPS_CONFIG}" >&2
    echo "## Image:  ${IMAGE}" >&2

    if [[ "${VERBOSE}" == true ]]; then
        echo "## Full command: ${ENGINE} ${RUN_ARGS[*]}" >&2
    fi
    if [[ "${ENGINE}" == "docker" ]]; then
        "${ENGINE}" --context default "${RUN_ARGS[@]}" || true
    else
        "${ENGINE}" "${RUN_ARGS[@]}" || true
    fi
    git_auto_commit "update context: ${CONTEXT_NAME:-unknown}"
}

###############################################################################
# clean subcommand
###############################################################################

clean_usage() {
    cat <<'EOF'
Usage: drt --clean [OPTIONS] [CONTEXT_NAME]

Remove SOPS config and/or AGE key for a context.

Options:
  --image TAG    Container image (default: localhost/d-rymcg-tech:latest)
  --docker       Use Docker instead of Podman
  --help         Show this help
EOF
}

cmd_clean() {
    local CONTEXT=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) IMAGE="$2"; shift 2 ;;
            --docker) ENGINE=docker; shift ;;
            --help) clean_usage; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                clean_usage >&2
                exit 1
                ;;
            *)
                if [[ -z "${CONTEXT}" ]]; then
                    CONTEXT="$1"
                else
                    echo "Error: unexpected argument: $1" >&2
                    clean_usage >&2
                    exit 1
                fi
                shift
                ;;
        esac
    done

    check_engine
    git_auto_pull

    if [[ -z "${CONTEXT}" ]]; then
        local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
        local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
        local CONTEXTS=()
        if [[ -d "${KEY_DIR}" ]]; then
            for f in "${KEY_DIR}"/*.key; do
                [[ -f "$f" ]] || continue
                CONTEXTS+=("$(basename "$f" .key)")
            done
        fi
        if [[ -d "${CONFIG_DIR}" ]]; then
            for f in "${CONFIG_DIR}"/*.sops.env; do
                [[ -f "$f" ]] || continue
                local name
                name="$(basename "$f" .sops.env)"
                local found=false
                for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                    if [[ "$c" == "$name" ]]; then found=true; break; fi
                done
                if [[ "$found" == false ]]; then
                    CONTEXTS+=("$name")
                fi
            done
        fi
        if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
            echo "Nothing to clean — no contexts found."
            return
        fi
        CONTEXT=$(wizard choose "Select context to clean" "${CONTEXTS[@]}")
    fi

    local CONFIG_FILE="${HOME}/.config/d.rymcg.tech/config/${CONTEXT}.sops.env"
    local AGE_KEY_FILE="${HOME}/.config/d.rymcg.tech/keys/sops/${CONTEXT}.key"
    local DELETED=false

    ## Delete SOPS config
    if [[ -f "${CONFIG_FILE}" ]]; then
        if wizard confirm "Delete SOPS config ${CONFIG_FILE}?" no; then
            rm -f "${CONFIG_FILE}"
            echo "Deleted: ${CONFIG_FILE}"
            DELETED=true
        else
            echo "Kept: ${CONFIG_FILE}"
        fi
    else
        echo "No SOPS config found: ${CONFIG_FILE}"
    fi

    ## Delete AGE key
    if [[ -f "${AGE_KEY_FILE}" ]]; then
        if wizard confirm "Delete AGE key ${AGE_KEY_FILE}?" no; then
            rm -f "${AGE_KEY_FILE}"
            echo "Deleted: ${AGE_KEY_FILE}"
            DELETED=true
        else
            echo "Kept: ${AGE_KEY_FILE}"
        fi
    else
        echo "No AGE key found: ${AGE_KEY_FILE}"
    fi

    if [[ "${DELETED}" == true ]]; then
        echo ""
        echo "Clean complete for context '${CONTEXT}'."
        git_auto_commit "remove context: ${CONTEXT}"
    else
        echo ""
        echo "Nothing was deleted."
    fi
}

###############################################################################
# git subcommand
###############################################################################

cmd_git() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    git -C "${CONFIG_BASE}" "$@"
}

cmd_git_init() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    ensure_config_dir

    if [[ -d "${CONFIG_BASE}/.git" ]]; then
        echo "Config repo already initialized at ${CONFIG_BASE}" >&2
        exit 0
    fi

    check_engine

    echo "Initialize ${CONFIG_BASE} as a git repository." >&2
    echo "SOPS configs will be tracked; AGE keys are excluded by .gitignore." >&2
    echo "" >&2
    if ! wizard confirm "Continue?" yes; then
        echo "Cancelled." >&2
        exit 0
    fi

    local BRANCH USER_EMAIL USER_NAME REMOTE
    local _default_branch
    _default_branch=$(git config --global init.defaultBranch 2>/dev/null || true)
    BRANCH=$(wizard ask "Branch name" "${_default_branch:-master}")
    local _default_email _default_name
    _default_email=$(git config --global user.email 2>/dev/null || true)
    _default_name=$(git config --global user.name 2>/dev/null || true)
    USER_EMAIL=$(wizard ask "Git email" "${_default_email}")
    USER_NAME=$(wizard ask "Git name" "${_default_name}")
    REMOTE=$(wizard ask "Git remote URL (e.g. ssh://git@github.com:22/you/drt-config.git)")

    ## Check if remote already has history — offer to clone instead
    if [[ -n "${REMOTE}" ]] && git ls-remote --heads "${REMOTE}" 2>/dev/null | grep -q .; then
        echo "" >&2
        echo "Remote ${REMOTE} already has commits." >&2
        echo "" >&2
        if wizard confirm "Clone from remote?" yes; then
            local tmpdir
            tmpdir=$(mktemp -d)
            git clone -b "${BRANCH}" "${REMOTE}" "${tmpdir}/repo"
            mv "${tmpdir}/repo/.git" "${CONFIG_BASE}/.git"
            rm -rf "${tmpdir}"
            git -C "${CONFIG_BASE}" config user.email "${USER_EMAIL}"
            git -C "${CONFIG_BASE}" config user.name "${USER_NAME}"
            git -C "${CONFIG_BASE}" checkout -- . 2>/dev/null || true
            echo "## Cloned config repo from ${REMOTE}" >&2
            return 0
        fi
    fi

    git -C "${CONFIG_BASE}" init -b "${BRANCH}"
    git -C "${CONFIG_BASE}" config user.email "${USER_EMAIL}"
    git -C "${CONFIG_BASE}" config user.name "${USER_NAME}"

    if [[ -n "${REMOTE}" ]]; then
        git -C "${CONFIG_BASE}" remote add origin "${REMOTE}"
    fi

    git -C "${CONFIG_BASE}" add -A
    git -C "${CONFIG_BASE}" commit -m "init" >/dev/null
    echo "## Config repo initialized at ${CONFIG_BASE}" >&2

    if [[ -n "${REMOTE}" ]]; then
        echo "" >&2
        echo "Remote: ${REMOTE}" >&2
        echo "" >&2
        if wizard confirm "Push to remote now?" yes; then
            git -C "${CONFIG_BASE}" push -u origin "${BRANCH}" && \
                echo "## Pushed" >&2 || \
                echo "## Push failed — check your remote URL and SSH keys" >&2
        fi
    fi
}

###############################################################################
# list subcommand
###############################################################################

cmd_list() {
    local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    local CONTEXTS=()

    ## Collect unique context names from keys and configs
    if [[ -d "${KEY_DIR}" ]]; then
        for f in "${KEY_DIR}"/*.key; do
            [[ -f "$f" ]] || continue
            CONTEXTS+=("$(basename "$f" .key)")
        done
    fi
    if [[ -d "${CONFIG_DIR}" ]]; then
        for f in "${CONFIG_DIR}"/*.sops.env; do
            [[ -f "$f" ]] || continue
            local name
            name="$(basename "$f" .sops.env)"
            ## Avoid duplicates
            local found=false
            for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                if [[ "$c" == "$name" ]]; then found=true; break; fi
            done
            if [[ "$found" == false ]]; then
                CONTEXTS+=("$name")
            fi
        done
    fi

    if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
        echo "No contexts found."
        return
    fi

    ## Sort contexts
    local SORTED
    SORTED=$(printf '%s\n' "${CONTEXTS[@]}" | sort)
    CONTEXTS=()
    while IFS= read -r ctx; do
        [[ -n "$ctx" ]] && CONTEXTS+=("$ctx")
    done <<< "$SORTED"

    printf "%-20s %-12s %s\n" "CONTEXT" "KEY" "CONFIG"
    printf "%-20s %-12s %s\n" "-------" "---" "------"
    for ctx in "${CONTEXTS[@]}"; do
        local key_status="missing"
        if [[ -f "${KEY_DIR}/${ctx}.key" ]]; then
            if head -1 "${KEY_DIR}/${ctx}.key" | grep -q '^age-encryption.org'; then
                key_status="encrypted"
            else
                key_status="plaintext!!"
            fi
        fi
        local config_status="missing"
        if [[ -f "${CONFIG_DIR}/${ctx}.sops.env" ]]; then
            config_status="${CONFIG_DIR}/${ctx}.sops.env"
        fi
        printf "%-20s %-12s %s\n" "$ctx" "$key_status" "$config_status"
    done
}

