cmd_git() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    git -C "${CONFIG_BASE}" "$@"
}

cmd_git_init() {
    local CONFIG_BASE="${HOME}/.config/d.rymcg.tech"
    ensure_config_dir

    if [[ -d "${CONFIG_BASE}/.git" ]]; then
        echo "Config repo already initialized at ${CONFIG_BASE}" >&2
        exit 0
    fi

    check_engine

    echo "Initialize ${CONFIG_BASE} as a git repository." >&2
    echo "SOPS configs will be tracked; AGE keys are excluded by .gitignore." >&2
    echo "" >&2
    if ! wizard confirm "Continue?" yes; then
        echo "Cancelled." >&2
        exit 0
    fi

    local BRANCH USER_EMAIL USER_NAME REMOTE
    BRANCH=$(wizard ask "Branch name" "master")
    local _default_email _default_name
    _default_email=$(git config --global user.email 2>/dev/null || true)
    _default_name=$(git config --global user.name 2>/dev/null || true)
    USER_EMAIL=$(wizard ask "Git email" "${_default_email}")
    USER_NAME=$(wizard ask "Git name" "${_default_name}")
    REMOTE=$(wizard ask "Git remote URL (e.g. ssh://git@github.com:22/you/drt-config.git)")

    git -C "${CONFIG_BASE}" init -b "${BRANCH}"
    git -C "${CONFIG_BASE}" config user.email "${USER_EMAIL}"
    git -C "${CONFIG_BASE}" config user.name "${USER_NAME}"

    if [[ -n "${REMOTE}" ]]; then
        git -C "${CONFIG_BASE}" remote add origin "${REMOTE}"
    fi

    git -C "${CONFIG_BASE}" add -A
    git -C "${CONFIG_BASE}" commit -m "init" >/dev/null
    echo "## Config repo initialized at ${CONFIG_BASE}" >&2

    if [[ -n "${REMOTE}" ]]; then
        echo "## Pushing to ${REMOTE} ..." >&2
        git -C "${CONFIG_BASE}" push -u origin "${BRANCH}" 2>/dev/null && \
            echo "## Pushed" >&2 || \
            echo "## Push failed — check your remote URL and SSH keys" >&2
    fi
}

###############################################################################
# list subcommand
###############################################################################

cmd_list() {
    local KEY_DIR="${HOME}/.config/d.rymcg.tech/keys/sops"
    local CONFIG_DIR="${HOME}/.config/d.rymcg.tech/config"
    local CONTEXTS=()

    ## Collect unique context names from keys and configs
    if [[ -d "${KEY_DIR}" ]]; then
        for f in "${KEY_DIR}"/*.key; do
            [[ -f "$f" ]] || continue
            CONTEXTS+=("$(basename "$f" .key)")
        done
    fi
    if [[ -d "${CONFIG_DIR}" ]]; then
        for f in "${CONFIG_DIR}"/*.sops.env; do
            [[ -f "$f" ]] || continue
            local name
            name="$(basename "$f" .sops.env)"
            ## Avoid duplicates
            local found=false
            for c in ${CONTEXTS[@]+"${CONTEXTS[@]}"}; do
                if [[ "$c" == "$name" ]]; then found=true; break; fi
            done
            if [[ "$found" == false ]]; then
                CONTEXTS+=("$name")
            fi
        done
    fi

    if [[ ${#CONTEXTS[@]} -eq 0 ]]; then
        echo "No contexts found."
        return
    fi

    ## Sort contexts
    local SORTED
    SORTED=$(printf '%s\n' "${CONTEXTS[@]}" | sort)
    CONTEXTS=()
    while IFS= read -r ctx; do
        [[ -n "$ctx" ]] && CONTEXTS+=("$ctx")
    done <<< "$SORTED"

    printf "%-20s %-12s %s\n" "CONTEXT" "KEY" "CONFIG"
    printf "%-20s %-12s %s\n" "-------" "---" "------"
    for ctx in "${CONTEXTS[@]}"; do
        local key_status="missing"
        if [[ -f "${KEY_DIR}/${ctx}.key" ]]; then
            if head -1 "${KEY_DIR}/${ctx}.key" | grep -q '^age-encryption.org'; then
                key_status="encrypted"
            else
                key_status="plaintext!!"
            fi
        fi
        local config_status="missing"
        if [[ -f "${CONFIG_DIR}/${ctx}.sops.env" ]]; then
            config_status="${CONFIG_DIR}/${ctx}.sops.env"
        fi
        printf "%-20s %-12s %s\n" "$ctx" "$key_status" "$config_status"
    done
}

