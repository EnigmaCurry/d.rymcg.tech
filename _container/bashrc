export TERM=${TERM:-xterm-256color}
alias ls="ls --color=auto"
PS1="\n\[\033[1;34m\][d.rymcg.tech|\[\033[1;32m\]${DRT_CONTEXT}\[\033[1;34m\]]\[\033[0m\] \[\033[1;33m\]\w\[\033[0m\]\n\$ "
eval "$(d.rymcg.tech completion bash)"
__d.rymcg.tech_cli_alias d
[ -n "${DRT_CONTEXT}" ] && type __d.rymcg.tech_context_alias &>/dev/null && __d.rymcg.tech_context_alias "${DRT_CONTEXT}" 2>/dev/null || true

## Save-on-exit: capture initial config state and diff on shell exit
if [[ "${SOPS_SAVE_ON_EXIT:-}" == "true" && -n "${SOPS_CONFIG_FILE:-}" ]]; then
    _sops_initial_state=$(mktemp)
    _sops_preserved_sections=$(mktemp)
    d export-env > "${_sops_initial_state}" 2>/dev/null || true

    ## Extract vars/comments from decrypted sops config that export-env doesn't produce
    ## (e.g. SSH_KNOWN_HOSTS, BAO_*, ## OpenBao header)
    _sops_extract_preserved() {
        local decrypted export_keys
        decrypted=$(sops decrypt --input-type dotenv --output-type dotenv \
            --filename-override export.env "${SOPS_CONFIG_FILE}" 2>/dev/null) || return 0
        # Get all keys that export-env produces
        export_keys=$(d export-env 2>/dev/null | grep -oP '^[A-Za-z_][A-Za-z_0-9]*(?==)' || true)
        local result=""
        while IFS= read -r line; do
            if [[ "${line}" == "## "* ]]; then
                # Preserve comment headers that export-env doesn't produce
                local header="${line#\#\# }"
                if [[ "${header}" != "SSH" && "${header}" != .env_* && "${header}" != */.env_* ]]; then
                    [[ -n "${result}" ]] && result+=$'\n'
                    result+="${line}"
                fi
            elif [[ "${line}" == *=* && "${line}" != "#"* ]]; then
                local key="${line%%=*}"
                # Preserve vars not in export-env output
                if ! echo "${export_keys}" | grep -qx "${key}"; then
                    [[ -n "${result}" ]] && result+=$'\n'
                    result+="${line}"
                fi
            fi
        done <<< "${decrypted}"
        echo -n "${result}"
    }
    _sops_extract_preserved > "${_sops_preserved_sections}"

    _sops_save_on_exit() {
        local current_state
        current_state=$(mktemp)
        d export-env > "${current_state}" 2>/dev/null || true

        if ! diff -q "${_sops_initial_state}" "${current_state}" &>/dev/null; then
            echo "" >&2
            echo "## Configuration changes detected:" >&2
            diff -u "${_sops_initial_state}" "${current_state}" >&2 || true
            echo "" >&2
            read -rp "Save changes to ${SOPS_CONFIG_FILE}? [y/N] " answer
            if [[ "${answer}" =~ ^[Yy]$ ]]; then
                local merged
                merged=$(mktemp)
                # Merge: preserved sections + export-env output
                if [[ -s "${_sops_preserved_sections}" ]]; then
                    cat "${_sops_preserved_sections}" > "${merged}"
                    echo "" >> "${merged}"
                    d export-env >> "${merged}" 2>/dev/null
                else
                    d export-env > "${merged}" 2>/dev/null
                fi
                if sops encrypt --input-type dotenv --output-type dotenv \
                       --filename-override export.env \
                       --age "${SOPS_AGE_RECIPIENTS}" "${merged}" > "${SOPS_CONFIG_FILE}"; then
                    echo "## Changes saved to ${SOPS_CONFIG_FILE}" >&2
                else
                    echo "ERROR: Failed to save changes" >&2
                fi
                rm -f "${merged}"
            else
                echo "## Changes discarded" >&2
            fi
        fi

        rm -f "${_sops_initial_state}" "${current_state}" "${_sops_preserved_sections}"
    }

    trap _sops_save_on_exit EXIT
fi
