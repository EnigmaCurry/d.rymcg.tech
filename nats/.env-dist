NATS_IMAGE=nats:2.12-alpine
NATS_STEP_CLI_IMAGE=smallstep/step-cli:latest

# Domain name for the NATS server (used for TLS certificate and HTTP monitoring UI):
NATS_TRAEFIK_HOST=nats.example.com

NATS_INSTANCE=
NATS_INSTANCE_PROTECTION=false

# NATS cluster/server name:
NATS_CLUSTER_NAME=nats

# Per-context config template is used based on the given docker context:
NATS_DOCKER_CONTEXT=

# Host port to expose for NATS client connections (TLS/mTLS):
NATS_CLIENT_PORT=4222

# Enable per-user subject authorization from the per-context authorization.conf template.
# Clients always need a valid TLS certificate signed by the CA to connect.
# When enabled, clients are restricted to the subjects defined in their user entry.
# See config/template/authorization.example.conf for the format.
NATS_AUTHORIZATION_ENABLE=true

# Step-CA configuration for mTLS:
NATS_STEP_CA_URL=
NATS_STEP_CA_FINGERPRINT=

# One-time-use token from Step-CA server:
# (Only used the first time the container volume is created.
# Usually expires 30m after the server issues it.
# If reinstalling, generate a new token first.)
NATS_STEP_CA_TOKEN=

# Client certificate expiration (hours):
NATS_CLIENT_CERT_EXPIRATION_HOURS=2160

# Filter access to the HTTP monitoring UI by IP address source range (CIDR):
# (This does NOT affect the NATS client TCP port)
##Disallow all access: 0.0.0.0/32
##Allow all access: 0.0.0.0/0
NATS_IP_SOURCERANGE=0.0.0.0/0

# HTTP Basic Authentication for the monitoring UI:
NATS_HTTP_AUTH=

# OAUTH2
# Set to true to use OpenID/OAuth2 authentication via the
# temporary access token (requires traefik-forward-auth):
NATS_OAUTH2=false
NATS_OAUTH2_AUTHORIZED_GROUP=

# Mutual TLS (mTLS) for the monitoring UI (via Traefik):
NATS_MTLS_AUTH=false
NATS_MTLS_AUTHORIZED_CERTS=*.clients.nats.example.com

# Homepage (portal) integration:
NATS_HOMEPAGE_LABELS_ENABLE=true
NATS_HOMEPAGE_GROUP_NATS=Messaging
NATS_HOMEPAGE_NAME_NATS=NATS
NATS_HOMEPAGE_ICON_NATS=nats
NATS_HOMEPAGE_DESCRIPTION_NATS=
NATS_HOMEPAGE_SHOW_STATS_NATS=true

# META:
# PREFIX=NATS
