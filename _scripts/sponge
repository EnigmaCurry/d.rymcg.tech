#!/usr/bin/env python3
# Auto-activate the project venv when invoked directly (outside the CLI/container)
import os as _os, sys as _sys
_venv = _os.path.join(_os.path.dirname(_os.path.dirname(_os.path.abspath(__file__))),
                      ".venv", "bin", "python3")
if _os.path.exists(_venv) and _os.path.abspath(_sys.executable) != _os.path.abspath(_venv):
    _os.execv(_venv, [_venv] + _sys.argv)
"""sponge - soak up stdin and write to a file (or stdout).

Drop-in replacement for moreutils sponge. Reads all of stdin into
memory before writing, so the output file can be the same as the
input file in a pipeline without data loss.

Usage:
  command | sponge [file]

If no file is given, writes to stdout.
"""
import sys

def main():
    data = sys.stdin.buffer.read()
    if len(sys.argv) > 1:
        with open(sys.argv[1], "wb") as f:
            f.write(data)
    else:
        sys.stdout.buffer.write(data)

if __name__ == "__main__":
    main()
