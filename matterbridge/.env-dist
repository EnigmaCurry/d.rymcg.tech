## Use different template based on which kind of bridging you want:
## Put all new templates into the config/template directory.
TEMPLATE=matterbridge.xmpp.matrix.toml

## Print the generated config file on startup?
PRINT_CONFIG=true

## Set whatever variables needed for the template:
MATRIX_DOMAIN=example.com
MATRIX_HOMESERVER=matrix.example.com
MATRIX_USERNAME=username
MATRIX_PASSWORD=a_secret_password

XMPP_HOST=xmpp.example.com
XMPP_PORT=5222
XMPP_JID=user@xmpp.example.com
XMPP_PASSWORD=a_secret_password
XMPP_MUC=conference.xmpp.example.com
XMPP_NICK=matterbridge


